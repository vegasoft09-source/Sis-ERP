@model Hevelab2026.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid p-0 animate-fade-in">
    <!-- Header Section -->
    <div class="row mb-4">
        <div class="col-12 d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3">
            <div>
                <h1 class="h3 fw-bold m-0" style="color: var(--text-primary);">Panel General</h1>
                <p class="m-0 mt-1" style="color: var(--text-muted); font-size: 13.5px;">Resumen ejecutivo y accesos rápidos de HeveLab ERP.</p>
            </div>
            <div class="d-flex align-items-center gap-2">
                <span class="hl-status-badge hl-badge-success px-3 py-2 d-flex align-items-center" style="font-size: 12px; gap: 6px;">
                    <span class="d-inline-block rounded-circle" style="width: 6px; height: 6px; background-color: currentColor;"></span>
                    Conectado a Producción
                </span>
            </div>
        </div>
    </div>

    <!-- ═══════════ METRICS GRID ═══════════ -->
    <div class="row g-3 mb-4">
        @foreach (var metric in Model.Metrics)
        {
            <div class="col-12 col-sm-6 col-xxl-3">
                <div class="card border-0 shadow-sm rounded-3 hl-metric-card h-100" style="background: var(--bg-topbar); border: 1px solid var(--border-color) !important; transition: transform 0.2s ease, box-shadow 0.2s ease;">
                    <div class="card-body p-4 d-flex flex-column justify-content-between">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <span class="fw-medium d-block mb-1" style="color: var(--text-muted); font-size: 13px;">@metric.Title</span>
                                <h3 class="fw-bold m-0" style="font-size: 24px; color: var(--text-primary); letter-spacing: -0.02em;">@metric.Value</h3>
                            </div>
                            <div class="hl-card-icon-wrap rounded-3 d-flex align-items-center justify-content-center">
                                <svg class="hl-icon" viewBox="0 0 24 24" style="width: 18px; height: 18px; stroke-width: 2;">
                                    @Html.Raw(metric.IconSvg)
                                </svg>
                            </div>
                        </div>
                        <div class="d-flex align-items-center mt-2" style="font-size: 12px; gap: 6px;">
                            @if (metric.TrendType == "up")
                            {
                                <span class="text-success fw-semibold d-inline-flex align-items-center gap-0.5">
                                    <svg class="hl-icon" viewBox="0 0 24 24" style="width: 14px; height: 14px; stroke: currentColor;"><polyline points="18 15 12 9 6 15"/></svg>
                                </span>
                                <span style="color: var(--text-secondary);">@metric.TrendText</span>
                            }
                            else if (metric.TrendType == "warning")
                            {
                                <span class="text-warning fw-semibold d-inline-flex align-items-center gap-0.5">
                                    <svg class="hl-icon" viewBox="0 0 24 24" style="width: 14px; height: 14px; stroke: currentColor;"><circle cx="12" cy="12" r="10"/><line x1="12" y1='8' x2='12' y2='12'/><line x1='12' y1='16' x2='12.01' y2='16'/></svg>
                                </span>
                                <span style="color: var(--text-secondary);">@metric.TrendText</span>
                            }
                            else
                            {
                                <span class="text-danger fw-semibold d-inline-flex align-items-center gap-0.5">
                                    <svg class="hl-icon" viewBox="0 0 24 24" style="width: 14px; height: 14px; stroke: currentColor;"><polyline points="6 9 12 15 18 9"/></svg>
                                </span>
                                <span style="color: var(--text-secondary);">@metric.TrendText</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- ═══════════ QUICK ACCESS MODULES ═══════════ -->
    <div class="row mb-3">
        <div class="col-12">
            <h2 class="h5 fw-bold m-0 mb-3" style="color: var(--text-primary);">Accesos Rápidos a Módulos</h2>
        </div>
    </div>
    
    <div class="row g-3 mb-5">
        @foreach (var module in Model.QuickAccessModules)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <a href="/@module.Controller" class="text-decoration-none hl-module-card-link">
                    <div class="card border-0 shadow-sm rounded-3 h-100 hl-module-card" 
                         style="background: var(--bg-topbar); border: 1px solid var(--border-color); transition: all 0.2s ease;">
                        <div class="card-body p-4 d-flex flex-column justify-content-between">
                            <div>
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <div class="hl-card-icon-wrap rounded-3 d-flex align-items-center justify-content-center">
                                        <svg class="hl-icon" viewBox="0 0 24 24" style="width: 18px; height: 18px; stroke-width: 2;">
                                            @Html.Raw(module.IconSvg)
                                        </svg>
                                    </div>
                                    @if (!string.IsNullOrEmpty(module.BadgeText))
                                    {
                                        <span class="hl-status-badge hl-badge-@module.BadgeType px-2.5 py-1" style="font-size: 11px;">
                                            @module.BadgeText
                                        </span>
                                    }
                                </div>
                                <h4 class="h6 fw-bold mb-2" style="color: var(--text-primary); font-size: 15px;">@module.Name</h4>
                                <p class="m-0" style="color: var(--text-secondary); font-size: 13px; line-height: 1.5; height: 60px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical;">
                                    @module.Description
                                </p>
                            </div>
                            <div class="d-flex align-items-center gap-1 mt-3 fw-semibold text-primary" style="font-size: 13px; color: var(--sys-primary) !important;">
                                Abrir módulo
                                <svg class="hl-icon" viewBox="0 0 24 24" style="width: 14px; height: 14px; transition: transform 0.2s ease;"><polyline points="9 18 15 12 9 6"/></svg>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>

    <!-- ═══════════ DOUBLE-COLUMN DETAIL PANEL ═══════════ -->
    <div class="row g-4">
        <!-- Left: Recent Sales -->
        <div class="col-12 col-xl-7">
            <div class="card border-0 shadow-sm rounded-3" style="background: var(--bg-topbar); border: 1px solid var(--border-color) !important;">
                <div class="card-header bg-transparent border-0 p-4 pb-0 d-flex justify-content-between align-items-center">
                    <h2 class="h6 fw-bold m-0" style="color: var(--text-primary); font-size: 15px;">Últimas Transacciones</h2>
                    <a href="/Ventas" class="text-decoration-none fw-semibold text-primary" style="font-size: 12.5px; color: var(--sys-primary) !important;">Ver todas</a>
                </div>
                <div class="card-body p-4 pt-3">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle m-0" style="min-width: 500px;">
                            <thead>
                                <tr style="border-bottom: 2px solid var(--border-color); font-size: 12px; color: var(--text-muted); text-transform: uppercase; font-weight: 600;">
                                    <th scope="col" class="pb-3 ps-0">Comprobante</th>
                                    <th scope="col" class="pb-3">Cliente</th>
                                    <th scope="col" class="pb-3">Fecha</th>
                                    <th scope="col" class="pb-3 text-end">Monto</th>
                                    <th scope="col" class="pb-3 text-end pe-0">Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var sale in Model.RecentSales)
                                {
                                    <tr style="border-bottom: 1px solid var(--border-color); font-size: 13.5px; color: var(--text-primary);">
                                        <td class="py-3 ps-0 fw-semibold">@sale.InvoiceNumber</td>
                                        <td class="py-3" style="color: var(--text-primary);">@sale.Customer</td>
                                        <td class="py-3" style="color: var(--text-muted); font-size: 12.5px;">@sale.Date</td>
                                        <td class="py-3 text-end fw-semibold">@sale.Amount</td>
                                        <td class="py-3 text-end pe-0">
                                            <span class="hl-status-badge hl-badge-@sale.StatusType px-2.5 py-1" style="font-size: 11px;">@sale.Status</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Recent Activities -->
        <div class="col-12 col-xl-5">
            <div class="card border-0 shadow-sm rounded-3" style="background: var(--bg-topbar); border: 1px solid var(--border-color) !important; height: 100%;">
                <div class="card-header bg-transparent border-0 p-4 pb-0">
                    <h2 class="h6 fw-bold m-0" style="color: var(--text-primary); font-size: 15px;">Actividad Reciente del Sistema</h2>
                </div>
                <div class="card-body p-4 pt-4">
                    <div class="position-relative ps-3" style="border-left: 2px solid var(--border-color);">
                        @for (int i = 0; i < Model.RecentActivities.Count; i++)
                        {
                            var act = Model.RecentActivities[i];
                            var isLast = i == Model.RecentActivities.Count - 1;
                            <div class="position-relative mb-4 @(isLast ? "mb-0" : "")">
                                <!-- Point on line -->
                                <span class="hl-timeline-point hl-timeline-point-@act.Type"></span>
                                <div>
                                    <p class="m-0 fw-medium" style="color: var(--text-primary); font-size: 13.5px; line-height: 1.4;">
                                        @act.Description
                                    </p>
                                    <div class="d-flex align-items-center gap-2 mt-1.5" style="font-size: 11.5px; color: var(--text-muted);">
                                        <span>@act.TimeAgo</span>
                                        <span>•</span>
                                        <span>Por: @act.User</span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Premium micro-interactions & transitions */
    .hl-metric-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-lg) !important;
    }
    
    .hl-module-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-lg) !important;
        border-color: var(--sys-ring) !important;
    }
    
    .hl-module-card-link:hover .text-primary .hl-icon {
        transform: translateX(4px);
    }

    .hl-card-icon-wrap {
        width: 40px;
        height: 40px;
        background-color: var(--bg-app);
        border: 1px solid var(--border-color);
        color: var(--text-secondary);
        transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
    }
    
    .hl-metric-card:hover .hl-card-icon-wrap,
    .hl-module-card:hover .hl-card-icon-wrap {
        background-color: rgba(67, 56, 202, 0.08) !important;
        border-color: var(--sys-ring) !important;
        color: var(--sys-primary) !important;
    }
    
    [data-theme="dark"] .hl-metric-card:hover .hl-card-icon-wrap,
    [data-theme="dark"] .hl-module-card:hover .hl-card-icon-wrap,
    [data-bs-theme="dark"] .hl-metric-card:hover .hl-card-icon-wrap,
    [data-bs-theme="dark"] .hl-module-card:hover .hl-card-icon-wrap {
        background-color: rgba(129, 140, 248, 0.12) !important;
        border-color: var(--sys-ring) !important;
        color: var(--sys-ring) !important;
    }

    .animate-fade-in {
        animation: fadeIn 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
