@using Hevelab2026.Models
@{
    var cliente = (Cliente)ViewBag.Cliente;
    // El breadcrumb y el título ya vienen del controlador
}

<div class="container-fluid p-0">
    <!-- Back Button -->
    <div class="mb-4">
        <a href="/Clientes" class="btn btn-sm btn-outline-secondary d-inline-flex align-items-center gap-1" style="border-color: var(--border-color); color: var(--text-primary); padding: 0.375rem 0.75rem; border-radius: 6px;">
            <svg class="hl-icon" viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Volver a Clientes
        </a>
    </div>

    <!-- Title Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <span class="text-uppercase font-monospace fw-bold text-xs d-block mb-1" style="color: var(--sys-primary); font-size: 0.75rem; letter-spacing: 1px;">Detalle del Cliente</span>
            <h1 class="h3 mb-0" style="color: var(--text-primary); font-weight: 700;">@cliente.RazonSocial</h1>
        </div>
        <a href="/Clientes/Formulario/@cliente.Id" class="btn" style="background: var(--sys-soft); color: var(--sys-primary); border: 1px solid var(--sys-border); font-weight: 500; border-radius: 6px; padding: 0.5rem 1rem;">
            Editar Cliente
        </a>
    </div>

    <!-- Main Info Cards -->
    <div class="card shadow-sm border mb-4" style="border-radius: 8px;">
        <div class="card-header bg-transparent py-3" style="border-bottom: 1px solid var(--border-color);">
            <h5 class="card-title mb-0" style="color: var(--text-primary); font-weight: 600; font-size: 1rem;">Ficha Informativa</h5>
        </div>
        <div class="card-body p-4">
            <div class="row g-4">
                <!-- Left Column - Identification -->
                <div class="col-md-6 border-end" style="border-color: var(--border-color) !important;">
                    <h6 class="text-uppercase fw-bold text-muted mb-3" style="font-size: 0.75rem; letter-spacing: 0.5px;">Datos de Identificación</h6>
                    <div class="row g-3">
                        <div class="col-4 text-muted fw-medium" style="font-size: 0.875rem;">Código:</div>
                        <div class="col-8 font-monospace fw-bold" style="color: var(--sys-primary); font-size: 0.875rem;">@cliente.Codigo</div>

                        <div class="col-4 text-muted fw-medium" style="font-size: 0.875rem;">Tipo Cliente:</div>
                        <div class="col-8" style="color: var(--text-primary); font-size: 0.875rem;">@cliente.TipoCliente</div>

                        <div class="col-4 text-muted fw-medium" style="font-size: 0.875rem;">Tipo Doc:</div>
                        <div class="col-8" style="color: var(--text-primary); font-size: 0.875rem;">@cliente.TipoDocumento</div>

                        <div class="col-4 text-muted fw-medium" style="font-size: 0.875rem;">N° Documento:</div>
                        <div class="col-8 fw-semibold" style="color: var(--text-primary); font-size: 0.875rem;">@cliente.NumeroDocumento</div>

                        <div class="col-4 text-muted fw-medium" style="font-size: 0.875rem;">Estado:</div>
                        <div class="col-8">
                            @if (cliente.Activo)
                            {
                                <span class="badge" style="background-color: var(--sys-primary); color: white; padding: 0.4em 0.75em; font-size: 0.75rem;">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary" style="padding: 0.4em 0.75em; font-size: 0.75rem;">Inactivo</span>
                            }
                        </div>
                    </div>
                </div>

                <!-- Right Column - Contact & Comercial -->
                <div class="col-md-6 ps-md-4">
                    <h6 class="text-uppercase fw-bold text-muted mb-3" style="font-size: 0.75rem; letter-spacing: 0.5px;">Contacto e Información Comercial</h6>
                    <div class="row g-3">
                        <div class="col-4 text-muted fw-medium" style="font-size: 0.875rem;">Teléfono:</div>
                        <div class="col-8" style="color: var(--text-primary); font-size: 0.875rem;">@(!string.IsNullOrEmpty(cliente.Telefono) ? cliente.Telefono : "-")</div>

                        <div class="col-4 text-muted fw-medium" style="font-size: 0.875rem;">Email:</div>
                        <div class="col-8" style="color: var(--text-primary); font-size: 0.875rem;">
                            <a href="mailto:@cliente.Email" style="color: var(--sys-primary);">@cliente.Email</a>
                        </div>

                        <div class="col-4 text-muted fw-medium" style="font-size: 0.875rem;">Dirección:</div>
                        <div class="col-8 text-truncate" style="color: var(--text-primary); font-size: 0.875rem;" title="@cliente.Direccion">@(!string.IsNullOrEmpty(cliente.Direccion) ? cliente.Direccion : "-")</div>

                        <div class="col-4 text-muted fw-medium" style="font-size: 0.875rem;">Ciudad:</div>
                        <div class="col-8" style="color: var(--text-primary); font-size: 0.875rem;">@(!string.IsNullOrEmpty(cliente.Ciudad) ? cliente.Ciudad : "-")</div>

                        <div class="col-4 text-muted fw-medium" style="font-size: 0.875rem;">Límite Crédito:</div>
                        <div class="col-8 fw-semibold" style="color: var(--text-primary); font-size: 0.875rem;">@cliente.LimiteCredito.ToString("C", new System.Globalization.CultureInfo("es-PE"))</div>

                        <div class="col-4 text-muted fw-medium" style="font-size: 0.875rem;">F. Registro:</div>
                        <div class="col-8" style="color: var(--text-primary); font-size: 0.875rem;">@cliente.FechaRegistro.ToString("dd/MM/yyyy")</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Metrics Row -->
    <div class="row g-3 mb-4">
        <!-- Metric 1 -->
        <div class="col-md-4">
            <div class="card shadow-sm border" style="border-radius: 8px; border-left: 4px solid var(--sys-primary) !important;">
                <div class="card-body p-3 d-flex align-items-center justify-content-between">
                    <div>
                        <span class="text-uppercase fw-semibold text-muted d-block" style="font-size: 0.75rem;">Cotizaciones</span>
                        <span class="h3 fw-bold mb-0 mt-1 d-block" style="color: var(--sys-primary);">4</span>
                    </div>
                    <div class="p-2 rounded-circle" style="background-color: var(--sys-soft); color: var(--sys-primary);">
                        <svg class="hl-icon hl-icon-lg" viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                            <polyline points="14 2 14 8 20 8"></polyline>
                            <line x1="16" y1="13" x2="8" y2="13"></line>
                            <line x1="16" y1="17" x2="8" y2="17"></line>
                            <polyline points="10 9 9 9 8 9"></polyline>
                        </svg>
                    </div>
                </div>
            </div>
        </div>

        <!-- Metric 2 -->
        <div class="col-md-4">
            <div class="card shadow-sm border" style="border-radius: 8px; border-left: 4px solid var(--sys-primary) !important;">
                <div class="card-body p-3 d-flex align-items-center justify-content-between">
                    <div>
                        <span class="text-uppercase fw-semibold text-muted d-block" style="font-size: 0.75rem;">Órdenes</span>
                        <span class="h3 fw-bold mb-0 mt-1 d-block" style="color: var(--sys-primary);">2</span>
                    </div>
                    <div class="p-2 rounded-circle" style="background-color: var(--sys-soft); color: var(--sys-primary);">
                        <svg class="hl-icon hl-icon-lg" viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="9" cy="21" r="1"></circle>
                            <circle cx="20" cy="21" r="1"></circle>
                            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                        </svg>
                    </div>
                </div>
            </div>
        </div>

        <!-- Metric 3 -->
        <div class="col-md-4">
            <div class="card shadow-sm border" style="border-radius: 8px; border-left: 4px solid var(--sys-primary) !important;">
                <div class="card-body p-3 d-flex align-items-center justify-content-between">
                    <div>
                        <span class="text-uppercase fw-semibold text-muted d-block" style="font-size: 0.75rem;">Total Facturado</span>
                        <span class="h3 fw-bold mb-0 mt-1 d-block" style="color: var(--sys-primary);">S/ 12,400.00</span>
                    </div>
                    <div class="p-2 rounded-circle" style="background-color: var(--sys-soft); color: var(--sys-primary);">
                        <svg class="hl-icon hl-icon-lg" viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="12" y1="1" x2="12" y2="23"></line>
                            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                        </svg>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bottom Tables -->
    <div class="card shadow-sm border mb-4" style="border-radius: 8px; overflow: hidden;">
        <div class="card-header bg-transparent py-3 border-bottom d-flex justify-content-between align-items-center" style="border-color: var(--border-color) !important;">
            <h5 class="card-title mb-0" style="color: var(--text-primary); font-weight: 600; font-size: 1rem;">Últimas cotizaciones</h5>
            <span class="badge bg-light text-dark border" style="border-color: var(--border-color) !important;">Simulado</span>
        </div>
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light" style="background-color: var(--bg-app); border-bottom: 1px solid var(--border-color);">
                    <tr>
                        <th class="ps-4" style="color: var(--text-secondary); font-weight: 600; font-size: 0.875rem;">N° Cotización</th>
                        <th style="color: var(--text-secondary); font-weight: 600; font-size: 0.875rem;">Fecha</th>
                        <th style="color: var(--text-secondary); font-weight: 600; font-size: 0.875rem;">Estado</th>
                        <th class="pe-4 text-end" style="color: var(--text-secondary); font-weight: 600; font-size: 0.875rem;">Total</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="ps-4 font-monospace fw-bold" style="color: var(--sys-primary);">COT-015</td>
                        <td>2026-05-20</td>
                        <td>
                            <span class="badge bg-warning text-dark" style="padding: 0.35em 0.6em; font-size: 0.7rem;">Pendiente</span>
                        </td>
                        <td class="pe-4 text-end fw-semibold">S/ 7,900.00</td>
                    </tr>
                    <tr>
                        <td class="ps-4 font-monospace fw-bold" style="color: var(--sys-primary);">COT-012</td>
                        <td>2026-05-15</td>
                        <td>
                            <span class="badge bg-success" style="padding: 0.35em 0.6em; font-size: 0.7rem;">Aprobada</span>
                        </td>
                        <td class="pe-4 text-end fw-semibold">S/ 4,500.00</td>
                    </tr>
                    <tr>
                        <td class="ps-4 font-monospace fw-bold" style="color: var(--sys-primary);">COT-009</td>
                        <td>2026-04-10</td>
                        <td>
                            <span class="badge bg-info text-dark" style="padding: 0.35em 0.6em; font-size: 0.7rem;">Facturada</span>
                        </td>
                        <td class="pe-4 text-end fw-semibold">S/ 2,400.00</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Final Actions -->
    <div class="d-flex justify-content-between align-items-center mt-4">
        <div>
            <span class="text-muted" style="font-size: 0.875rem;">Creado por Administrador</span>
        </div>
        <div class="d-inline-flex gap-2">
            <a href="/Clientes" class="btn btn-outline-secondary" style="border-color: var(--border-color); color: var(--text-primary); border-radius: 6px; font-weight: 500;">
                Regresar al listado
            </a>
            <a href="/Clientes/Formulario/@cliente.Id" class="btn" style="background: var(--sys-primary); color: var(--sys-on-primary); border: none; border-radius: 6px; font-weight: 500; padding: 0.5rem 1.25rem;">
                Editar Ficha
            </a>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .table { color: var(--text-primary); border-color: var(--border-color); }
        .table-hover tbody tr:hover { background: var(--sys-soft-bg); }
        .card { border-color: var(--border-color); background: var(--bg-sidebar); }
        .table-light { background-color: var(--bg-app); }
    </style>
}
