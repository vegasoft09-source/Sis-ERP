                            <span style="font-size:10px; font-weight:700; color:var(--cta-text-muted); text-transform:uppercase; letter-spacing:0.3px;">${d.tipoDoc}</span>
                            <p style="font-size:12px; color:var(--cta-text-secondary); margin:8px 0; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; height:32px; line-height:1.3;">${d.descripcion}</p>
                            
                            <!-- Detalles de Base -->
                            <div style="display:flex; justify-content:space-between; align-items:center; font-size:11px; color:var(--cta-text-muted); margin-top:auto; padding-top:8px; border-top:1px solid #f1f5f9;">
                                <span>${dateStr}</span>
                                <span>${sizeStr}</span>
                            </div>
                            
                            <!-- Chips / Etiquetas -->
                            <div style="display:flex; gap:4px; flex-wrap:wrap; margin-top:8px;" onclick="event.stopPropagation();">
                                ${d.etiquetas.map(tag => {
                                    var isSelected = (tag === activeTagFilter);
                                    var tagStyle = isSelected 
                                        ? "background: var(--cta-primary); color: #ffffff; border: 1px solid var(--cta-primary); font-weight: 700;"
                                        : "background: #f1f5f9; color: var(--cta-text-secondary);";
                                    return `<span onclick="filterByTag(event, '${tag}')" style="${tagStyle} font-size:9.5px; padding:2px 6px; border-radius:4px; transition: all var(--cta-transition); cursor: pointer;">${tag}</span>`;
