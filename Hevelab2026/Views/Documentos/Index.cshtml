                            </div>
                        </div>
                    </div>
                `;
                gridContainer.insertAdjacentHTML("beforeend", cardHtml);
            });
        }
    }

    // --- VISTA LISTA ---
    function renderListView(filtered) {
        var listBody = document.getElementById("doc-list-body");
        listBody.innerHTML = "";
        
        if (filtered.length === 0) {
            listBody.innerHTML = `<tr><td colspan="9" style="text-align: center; padding: 24px; color: var(--cta-text-muted); font-style: italic;">No se encontraron documentos contables con los filtros seleccionados.</td></tr>`;
        } else {
            filtered.forEach(function(d) {
                var dateStr = stringJoinReverse(d.fechaSubida);
                var sizeStr = formatKB(d.tamanoKB);
                var iconSvg = getSmallIconHtml(d.extension);
                var isChecked = selectedDocIds.has(d.id);

                var rowHtml = `
                    <tr style="border-bottom: 1px solid var(--cta-border); transition: background var(--cta-transition); cursor: pointer;" onclick="openPreviewDrawer(${d.id})" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='none'">
                        
                        <!-- Checkbox -->
                        <td style="padding: 10px 16px; text-align: center;" onclick="event.stopPropagation();">
                            <input type="checkbox" class="doc-selector-checkbox" data-id="${d.id}" ${isChecked ? 'checked' : ''} onclick="handleCheckboxClick(event, ${d.id})" style="width: 15px; height: 15px; cursor: pointer; accent-color: var(--cta-primary);" />
                        </td>

                        <td style="padding: 10px 16px; text-align: center;">${iconSvg}</td>
                        <td style="padding: 10px 16px; font-weight: 600; max-width: 250px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="${d.nombre}">${d.nombre}</td>
                        <td style="padding: 10px 16px;">${d.tipoDoc}</td>
                        <td style="padding: 10px 16px;"><span style="background:#f1f5f9; color:var(--cta-text-secondary); padding:4px 8px; border-radius:4px; font-size:11px; font-weight:600;">${d.categoria}</span></td>
                        <td style="padding: 10px 16px;">${dateStr}</td>
                        <td style="padding: 10px 16px; text-align: right; font-family: monospace;">${sizeStr}</td>
                        <td style="padding: 10px 16px; text-align: center;">
                            <span style="background: ${d.estado === 'Activo' ? 'rgba(16, 185, 129, 0.1)' : 'rgba(217, 119, 6, 0.1)'}; color: ${d.estado === 'Activo' ? '#10b981' : '#d97706'}; border: 1px solid ${d.estado === 'Activo' ? 'rgba(16, 185, 129, 0.2)' : 'rgba(217, 119, 6, 0.2)'}; padding: 3px 8px; border-radius: 9999px; font-size: 11px; font-weight: 600;">
                                ${d.estado}
                            </span>
                        </td>
                        <td style="padding: 10px 16px; text-align: center; position: relative;" onclick="event.stopPropagation();">
                            <button onclick="openPreviewDrawer(${d.id})" style="background:none; border:none; color:var(--cta-primary); font-weight:600; cursor:pointer; font-size:12px; margin-right:8px;">Ver</button>
                            <button onclick="downloadDoc(${d.id})" style="background:none; border:none; color:var(--cta-text-secondary); cursor:pointer; font-size:12px; margin-right:8px;">Descargar</button>
                            <button onclick="archiveDoc(event, ${d.id})" style="background:none; border:none; color:#d97706; cursor:pointer; font-size:12px;">${d.estado === 'Activo' ? 'Archivar' : 'Restaurar'}</button>
                        </td>
                    </tr>
                `;
                listBody.insertAdjacentHTML("beforeend", rowHtml);
            });
        }
    }

    // --- RECALCULAR CONTADORES SIDEBAR ---
    function updateCategoryCounters() {
        var countAll = dbDocs.filter(d => d.estado === "Activo").length;
        var countVentas = dbDocs.filter(d => d.categoria === "Ventas" && d.estado === "Activo").length;
        var countCompras = dbDocs.filter(d => d.categoria === "Compras" && d.estado === "Activo").length;
        var countImpuestos = dbDocs.filter(d => d.categoria === "Impuestos" && d.estado === "Activo").length;
        var countCierre = dbDocs.filter(d => d.categoria === "Cierre" && d.estado === "Activo").length;
        var countArchived = dbDocs.filter(d => d.estado === "Archivado").length;

        document.getElementById("count-all").textContent = countAll;
        document.getElementById("count-ventas").textContent = countVentas;
        document.getElementById("count-compras").textContent = countCompras;
        document.getElementById("count-impuestos").textContent = countImpuestos;
        document.getElementById("count-cierre").textContent = countCierre;
        document.getElementById("count-archivados").textContent = countArchived;
    }

    // --- 4. GESTIÓN ETIQUETAS CLIENT-SIDE ---
    function filterByTag(e, tag) {
        if (e) {
            e.stopPropagation();
            e.preventDefault();
        }
        activeTagFilter = tag;
        renderDocs();
    }

    function clearTagFilter() {
        activeTagFilter = null;
        renderDocs();
    }

    // --- 6. ORDENAMIENTO EN TIEMPO REAL ---
    function handleSortChange() {
        renderDocs();
    }

    // --- ACCIONES INDIVIDUALES ---
    function toggleDropdown(event, id) {
        event.stopPropagation();
        var menu = document.getElementById("dropdown-" + id);
        var isOpen = menu.style.display === "block";
        
        // Cerrar todos los abiertos
        document.querySelectorAll(".cta-dropdown-menu").forEach(m => m.style.display = "none");
        
        if (!isOpen) {
            menu.style.display = "block";
            
            // Cerrar menú si hace click fuera
            var closeHandler = function() {
                menu.style.display = "none";
                document.removeEventListener("click", closeHandler);
            };
            setTimeout(() => document.addEventListener("click", closeHandler), 10);
        }
    }

    function archiveDoc(event, id) {
        if (event) event.stopPropagation();
        var doc = dbDocs.find(d => d.id === id);
        if (doc) {
            if (doc.estado === "Activo") {
                doc.estado = "Archivado";
                showToast("Archivo Archivado", `"${doc.nombre}" ha sido movido a la sección de Archivados.`, "warning");
            } else {
                doc.estado = "Activo";
                showToast("Archivo Restaurado", `"${doc.nombre}" ha sido restaurado exitosamente.`, "success");
            }
            updateCategoryCounters();
            renderDocs();
            
            // Si el drawer está abierto, refrescarlo o cerrarlo
            var drawer = document.getElementById("cta-preview-drawer");
            if (drawer.classList.contains("open")) {
                closePreviewDrawer();
            }
        }
    }

    function downloadDoc(id) {
        var doc = dbDocs.find(d => d.id === id);
        if (doc) {
            // Simular descarga creando un Blob
            var mockContent = `HEVELAB 2026 - MOCK DOWNLOAD\r\n` +
                              `===========================\r\n` + 
                              `Nombre del Archivo: ${doc.nombre}\r\n` + 
                              `Tipo de Documento: ${doc.tipoDoc}\r\n` + 
                              `Categoría Contable: ${doc.categoria}\r\n` + 
                              `Fecha de Registro: ${doc.fechaSubida}\r\n` + 
                              `Tamaño de Documento: ${formatKB(doc.tamanoKB)}\r\n` +
                              `Subido Por: ${doc.subidoPor}\r\n` +
                              `Estado en el Gestor: ${doc.estado}\r\n\r\n` +
                              `Descripción: ${doc.descripcion}\r\n`;
            
            var blob = new Blob([mockContent], { type: "text/plain;charset=utf-8" });
            var url = URL.createObjectURL(blob);
            var a = document.createElement("a");
            a.href = url;
            a.download = doc.nombre.replace(".pdf", ".txt").replace(".xlsx", ".txt").replace(".xml", ".txt"); 
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
            
            showToast("Descarga Iniciada", `Descargando comprobante "${doc.nombre}" en formato descriptivo.`, "success");
        }
    }

