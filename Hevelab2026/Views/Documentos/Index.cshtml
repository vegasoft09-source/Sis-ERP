    function closePreviewDrawer() {
        var overlay = document.getElementById("cta-drawer-overlay");
        var drawer = document.getElementById("cta-preview-drawer");
        if (overlay && drawer) {
            overlay.classList.remove("active");
            drawer.classList.remove("open");
        }
    }

    // --- MANEJO DE ETIQUETAS EN PREVIEW ---
    function renderDrawerTags(doc) {
        var container = document.getElementById("drawer-tags-container");
        if (!container) return;
        container.innerHTML = "";

        doc.etiquetas.forEach(function(tag) {
            var chip = document.createElement("span");
            chip.style.cssText = "background: var(--cta-primary-soft); color: var(--cta-primary); font-size: 11px; font-weight: 700; padding: 4px 8px; border-radius: 4px; display: inline-flex; align-items: center; gap: 5px; cursor: pointer;";
            chip.innerHTML = `#${tag} <span onclick="removeTagFromDoc(event, ${doc.id}, '${tag}')" style="cursor: pointer; opacity: 0.7; font-weight: bold; font-size: 12px; margin-left: 2px;">&times;</span>`;
            chip.onclick = function() {
                closePreviewDrawer();
                filterByTag(null, tag);
            };
            container.appendChild(chip);
        });

        // Botón agregar
        var addBtn = document.createElement("button");
        addBtn.className = "cta-add-tag-btn";
        addBtn.style.cssText = "background: #f1f5f9; border: 1px solid var(--cta-border); color: var(--cta-text-secondary); font-size: 11px; font-weight: 600; padding: 4px 10px; border-radius: 4px; cursor: pointer; transition: all 0.2s; outline: none; border-style: dashed;";
        addBtn.textContent = "+ Agregar etiqueta";
        addBtn.onclick = showAddTagInput;
        container.appendChild(addBtn);
    }

    function showAddTagInput() {
        var container = document.getElementById("add-tag-input-container");
        if (container) {
            container.style.display = "block";
            var input = document.getElementById("new-tag-input");
            if (input) input.focus();
        }
    }

    function handleNewTagKeydown(event, id) {
        if (event.key === "Enter") {
            event.preventDefault();
            var input = document.getElementById("new-tag-input");
            var val = input.value.trim();
            if (val) {
                var doc = dbDocs.find(d => d.id === id);
                if (doc) {
                    if (!doc.etiquetas.includes(val)) {
                        doc.etiquetas.push(val);
                        showToast("Etiqueta Agregada", `Se agregó la etiqueta "#${val}" a "${doc.nombre}".`, "success");
                        renderDrawerTags(doc);
                        renderDocs();
                    } else {
                        showToast("Etiqueta Existente", `El archivo ya cuenta con la etiqueta "${val}".`, "info");
                    }
                    input.value = "";
                    document.getElementById("add-tag-input-container").style.display = "none";
                }
            }
        }
    }

    function removeTagFromDoc(event, docId, tag) {
        event.stopPropagation();
        var doc = dbDocs.find(d => d.id === docId);
        if (doc) {
            doc.etiquetas = doc.etiquetas.filter(t => t !== tag);
            showToast("Etiqueta Eliminada", `Se removió la etiqueta "#${tag}".`, "warning");
            renderDrawerTags(doc);
            renderDocs();
        }
    }

    // --- 2. ZONA DRAG & DROP ---
    function toggleDragDropZone() {
        var zone = document.getElementById("drag-drop-collapsible-zone");
        var indicator = document.getElementById("drag-drop-toggle-indicator");
        if (zone.style.maxHeight === "0px") {
            zone.style.maxHeight = "200px";
            indicator.textContent = "▼ Colapsar";
            isDragDropZoneCollapsed = false;
        } else {
            zone.style.maxHeight = "0px";
            indicator.textContent = "▲ Expandir";
            isDragDropZoneCollapsed = true;
        }
    }

    function handleDragOver(e) {
        e.preventDefault();
        e.stopPropagation();
        var dz = document.getElementById("drop-zone");
        dz.style.backgroundColor = "var(--cta-primary-soft)";
        dz.style.borderColor = "var(--cta-primary)";
    }

    function handleDragLeave(e) {
        e.preventDefault();
        e.stopPropagation();
        var dz = document.getElementById("drop-zone");
        dz.style.backgroundColor = "#f8fafc";
        dz.style.borderColor = "var(--cta-border)";
    }

    function handleDrop(e) {
        e.preventDefault();
        e.stopPropagation();
        handleDragLeave(e);
        var files = e.dataTransfer.files;
        processUploadedFiles(files);
    }

    function triggerFileInput() {
        document.getElementById("file-input-hidden").click();
    }

    function handleFileSelect(e) {
        var files = e.target.files;
        processUploadedFiles(files);
    }

    function processUploadedFiles(files) {
        if (!files || files.length === 0) return;
        var loadedCount = 0;
        for (var i = 0; i < files.length; i++) {
            var file = files[i];
            var name = file.name;
            var ext = name.split('.').pop().toLowerCase();
            if (ext !== "pdf" && ext !== "xlsx" && ext !== "xml") {
                ext = "pdf"; // Fallback predeterminado
            }
            var sizeKB = Math.round(file.size / 1024) || 120;
            var today = new Date().toISOString().split('T')[0];
            
            var newId = dbDocs.length > 0 ? Math.max(...dbDocs.map(d => d.id)) + 1 : 1;
            
            // Determinar categoría por nombre de archivo
            var defaultCat = "Ventas";
            if (name.toLowerCase().includes("compra")) defaultCat = "Compras";
            else if (name.toLowerCase().includes("impuesto") || name.toLowerCase().includes("sunat") || name.toLowerCase().includes("pdt")) defaultCat = "Impuestos";
            else if (name.toLowerCase().includes("cierre") || name.toLowerCase().includes("balance") || name.toLowerCase().includes("reporte") || name.toLowerCase().includes("planilla")) defaultCat = "Cierre";

            var newDoc = {
                id: newId,
                nombre: name,
                descripcion: "Documento contable digital cargado vía arrastre y Drag & Drop.",
                tipoDoc: ext === "pdf" ? "Factura" : ext === "xlsx" ? "Reporte" : "Declaración",
                categoria: defaultCat,
                fechaSubida: today,
                tamanoKB: sizeKB,
                extension: ext,
                subidoPor: "Usuario Admin",
                etiquetas: [defaultCat, ext.toUpperCase()],
                estado: "Activo"
            };
            dbDocs.push(newDoc);
            loadedCount++;
        }
        updateCategoryCounters();
        renderDocs();
        showToast("Carga Completada", `${loadedCount} archivo(s) se han procesado e incorporado exitosamente.`, "success");
    }

    // --- 3. BÚSQUEDA AVANZADA ---
    function toggleAdvancedSearch() {
        var panel = document.getElementById("adv-search-panel");
        var btn = document.getElementById("btn-adv-search");
        if (panel.style.display === "none") {
            panel.style.display = "block";
            btn.classList.add("active");
        } else {
            panel.style.display = "none";
            btn.classList.remove("active");
        }
    }

    function applyAdvancedFilters() {
        var nombre = document.getElementById("adv-nombre").value.trim();
        var desde = document.getElementById("adv-fecha-desde").value;
        var hasta = document.getElementById("adv-fecha-hasta").value;
        var tmin = document.getElementById("adv-tam-min").value;
        var tmax = document.getElementById("adv-tam-max").value;
        var tagsRaw = document.getElementById("adv-etiquetas").value.trim();

        // Checkboxes de Tipo
        var checkedTypes = [];
        document.querySelectorAll(".adv-tipo-check:checked").forEach(function(cb) {
            checkedTypes.push(cb.value);
        });

        activeAdvancedFilters.nombre = nombre;
        activeAdvancedFilters.fechaDesde = desde;
        activeAdvancedFilters.fechaHasta = hasta;
        activeAdvancedFilters.sizeMin = tmin ? parseInt(tmin) : null;
        activeAdvancedFilters.sizeMax = tmax ? parseInt(tmax) : null;
        activeAdvancedFilters.etiquetas = tagsRaw ? tagsRaw.split(",").map(t => t.trim()) : [];
        activeAdvancedFilters.tipos = checkedTypes;

        showToast("Filtros Aplicados", "La grilla se ha filtrado con los parámetros avanzados.", "info");
        renderDocs();
    }

    function clearAdvancedFilters() {
        document.getElementById("adv-nombre").value = "";
        document.getElementById("adv-fecha-desde").value = "";
        document.getElementById("adv-fecha-hasta").value = "";
        document.getElementById("adv-tam-min").value = "";
        document.getElementById("adv-tam-max").value = "";
        document.getElementById("adv-etiquetas").value = "";
        
        document.querySelectorAll(".adv-tipo-check").forEach(cb => cb.checked = true);

        activeAdvancedFilters = {
            nombre: "",
            fechaDesde: "",
            fechaHasta: "",
            sizeMin: null,
            sizeMax: null,
            etiquetas: [],
            tipos: ["Factura", "Estado de Cuenta", "Declaración", "Contrato", "Reporte", "Otro"]
        };

        showToast("Filtros Reiniciados", "Se han restablecido los documentos a la vista normal.", "info");
        renderDocs();
    }

    // --- 5. SELECCIÓN MÚLTIPLE ---
    function handleCheckboxClick(event, id) {
        event.stopPropagation();
        if (event.target.checked) {
            selectedDocIds.add(id);
        } else {
            selectedDocIds.delete(id);
        }
        updateFloatingActionBar();
    }

    function toggleSelectAll(masterCheckbox) {
        var checkboxes = document.querySelectorAll(".doc-selector-checkbox");
        checkboxes.forEach(function(cb) {
            var id = parseInt(cb.getAttribute("data-id"));
            cb.checked = masterCheckbox.checked;
            if (masterCheckbox.checked) {
                selectedDocIds.add(id);
            } else {
                selectedDocIds.delete(id);
            }
        });

        // Sincronizar los dos master checkboxes
        var masterList = document.getElementById("check-all-docs");
        var masterGrid = document.getElementById("check-all-docs-grid");
        if (masterList) masterList.checked = masterCheckbox.checked;
        if (masterGrid) masterGrid.checked = masterCheckbox.checked;

        updateFloatingActionBar();
    }

    function updateFloatingActionBar() {
        var bar = document.getElementById("cta-floating-actions-bar");
        var countSpan = document.getElementById("selected-count");
        if (selectedDocIds.size > 0) {
            countSpan.textContent = selectedDocIds.size;
            bar.style.display = "flex";
            setTimeout(() => bar.classList.add("active"), 10);
        } else {
            bar.classList.remove("active");
            setTimeout(() => bar.style.display = "none", 300);
            
            // Apagar checks maestros
            var masterList = document.getElementById("check-all-docs");
            var masterGrid = document.getElementById("check-all-docs-grid");
            if (masterList) masterList.checked = false;
            if (masterGrid) masterGrid.checked = false;
        }
    }

    function cancelSelection() {
        selectedDocIds.clear();
        document.querySelectorAll(".doc-selector-checkbox").forEach(cb => cb.checked = false);
        
        var masterList = document.getElementById("check-all-docs");
        var masterGrid = document.getElementById("check-all-docs-grid");
        if (masterList) masterList.checked = false;
        if (masterGrid) masterGrid.checked = false;

        updateFloatingActionBar();
    }

    function archiveSelected() {
        if (selectedDocIds.size === 0) return;
        var count = 0;
        selectedDocIds.forEach(function(id) {
            var doc = dbDocs.find(d => d.id === id);
            if (doc && doc.estado === "Activo") {
                doc.estado = "Archivado";
                count++;
            }
        });
        showToast("Selección Archivada", `${count} archivo(s) se han movido a la sección de Archivados.`, "warning");
        cancelSelection();
        updateCategoryCounters();
        renderDocs();
    }

    function downloadZipSelected() {
        if (selectedDocIds.size === 0) return;
        
        // Simular descarga de paquete comprimido ZIP
        var fileNames = [];
        selectedDocIds.forEach(id => {
            var doc = dbDocs.find(d => d.id === id);
            if (doc) fileNames.push(doc.nombre);
        });

        var zipSimulatedContent = `HEVELAB ERP 2026 - CONTABILIDAD\r\n` +
                                  `PAQUETE COMPRIMIDO ZIP SIMULADO\r\n` + 
                                  `===================================\r\n` +
                                  `Cantidad de Archivos: ${selectedDocIds.size}\r\n\r\n` +
                                  `Archivos Incluidos:\r\n` + 
                                  fileNames.map((n, i) => `  [${i+1}] ${n}`).join("\r\n");

        var blob = new Blob([zipSimulatedContent], { type: "application/zip" });
        var url = URL.createObjectURL(blob);
        var a = document.createElement("a");
        a.href = url;
        a.download = "comprobantes_contables_hevelab.zip";
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);

        showToast("ZIP Generado", `Descargando paquete comprimido con ${selectedDocIds.size} archivos.`, "success");
        cancelSelection();
    }

    // --- AUXILIARES ---
    function formatKB(kb) {
        if (kb >= 1024) {
            return (kb / 1024).toFixed(2) + " MB";
        }
        return kb + " KB";
    }

    function stringJoinReverse(dateStr) {
        if (!dateStr) return "-";
        var parts = dateStr.split("-");
        if (parts.length === 3) {
            return parts[2] + "/" + parts[1] + "/" + parts[0];
        }
        return dateStr;
    }

    function getLargeIconHtml(ext) {
        if (ext === "pdf") {
            return `
                <svg viewBox="0 0 24 24" style="width: 48px; height: 48px; fill: none; stroke: #ef4444; stroke-width: 1.5; filter: drop-shadow(0 4px 6px rgba(239, 68, 68, 0.15));">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                    <line x1="16" y1="13" x2="8" y2="13"></line>
                    <line x1="16" y1="17" x2="8" y2="17"></line>
                    <text x="6" y="15" fill="#ef4444" font-size="4px" font-weight="900" font-family="sans-serif">PDF</text>
                </svg>
            `;
        }
        if (ext === "xlsx") {
            return `
                <svg viewBox="0 0 24 24" style="width: 48px; height: 48px; fill: none; stroke: #10b981; stroke-width: 1.5; filter: drop-shadow(0 4px 6px rgba(16, 185, 129, 0.15));">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                    <rect x="8" y="12" width="8" height="6" rx="1"></rect>
                    <line x1="12" y1="12" x2="12" y2="18"></line>
                    <line x1="8" y1="15" x2="16" y2="15"></line>
                </svg>
            `;
        }
        return `
            <svg viewBox="0 0 24 24" style="width: 48px; height: 48px; fill: none; stroke: #3b5bdb; stroke-width: 1.5; filter: drop-shadow(0 4px 6px rgba(59, 93, 219, 0.15));">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                <polyline points="14 2 14 8 20 8"></polyline>
                <polyline points="8 13 6 15 8 17"></polyline>
                <polyline points="16 13 18 15 16 17"></polyline>
                <line x1="13" y1="12" x2="11" y2="18"></line>
            </svg>
        `;
    }

    function getSmallIconHtml(ext) {
        var color = "#3b5bdb";
        if (ext === "pdf") color = "#ef4444";
        if (ext === "xlsx") color = "#10b981";
        
        return `
            <svg viewBox="0 0 24 24" style="width: 18px; height: 18px; fill: none; stroke: ${color}; stroke-width: 2.2; stroke-linecap: round; stroke-linejoin: round;">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                <polyline points="14 2 14 8 20 8"></polyline>
            </svg>
        `;
    }

    // --- MODALES AUXILIARES ---
    function openUploadModal() {
        var modal = document.getElementById("cta-upload-modal");
        var card = document.getElementById("cta-upload-card");
        
        // Limpiar formulario
        document.getElementById("up-nombre").value = "";
        document.getElementById("up-desc").value = "";
        document.getElementById("up-tags").value = "";
        document.getElementById("up-tam").value = Math.floor(Math.random() * (1200 - 50) + 50);

        modal.style.display = "flex";
        setTimeout(function() {
            modal.style.opacity = "1";
            card.style.transform = "scale(1)";
        }, 10);
    }

    function closeUploadModal() {
        var modal = document.getElementById("cta-upload-modal");
        var card = document.getElementById("cta-upload-card");
        if (modal && card) {
            modal.style.opacity = "0";
            card.style.transform = "scale(0.95)";
            setTimeout(function() {
                modal.style.display = "none";
            }, 200);
        }
    }

    // --- SISTEMA TOAST NOTIFICACIONES ---
    function showToast(title, message, type = "success") {
        var color = "#10b981";
        if (type === "warning") color = "#d97706";
        if (type === "info") color = "#3b5bdb";
        
        var toastHtml = `
            <div class="cta-toast" style="position: fixed; top: 20px; right: 20px; background: #ffffff; border-left: 4px solid ${color}; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05); border-radius: 6px; padding: 12px 18px; z-index: 10000; animation: toastSlideIn 0.3s cubic-bezier(0.4, 0, 0.2, 1); display: flex; align-items: center; gap: 12px; min-width: 280px; max-width: 400px; box-sizing: border-box;">
                <div style="flex: 1;">
                    <h5 style="margin: 0; font-size: 13px; font-weight: 700; color: var(--cta-text-primary);">${title}</h5>
                    <p style="margin: 2px 0 0 0; font-size: 12px; color: var(--cta-text-secondary);">${message}</p>
                </div>
                <button style="background: none; border: none; font-size: 16px; color: var(--cta-text-muted); cursor: pointer;" onclick="this.parentElement.remove()">&times;</button>
            </div>
        `;
        document.body.insertAdjacentHTML("beforeend", toastHtml);
        
        var toasts = document.querySelectorAll(".cta-toast");
        var lastToast = toasts[toasts.length - 1];
        setTimeout(function() {
            if (lastToast) {
                lastToast.style.opacity = "0";
                lastToast.style.transform = "translateY(-10px)";
                lastToast.style.transition = "all 0.3s ease";
                setTimeout(function() {
                    lastToast.remove();
                }, 300);
            }
        }, 3500);
    }
</script>
