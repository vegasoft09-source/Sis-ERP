<!-- Motor JavaScript del Lado del Cliente -->
<script>
    // Inyectar datos desde C#
    var dbDocs = [
        @foreach (var d in documentos)
        {
            <text>{ id: @d.Id, nombre: "@d.Nombre", descripcion: "@d.Descripcion", tipoDoc: "@d.TipoDocumento", categoria: "@d.Categoria", fechaSubida: "@d.FechaSubida", tamanoKB: @d.TamanoKB, extension: "@d.Extension", subidoPor: "@d.SubidoPor", etiquetas: [@Html.Raw(string.Join(",", d.Etiquetas.Select(t => $"\"{t}\"")))], estado: "@d.Estado" },</text>
        }
    ];

    // Variables de Estado Globales
    var activeCategory = "all";
    var activeFormatFilter = "all";
    var activeTagFilter = null;
    var selectedDocIds = new Set();
    var currentSort = "recent";
    var isDragDropZoneCollapsed = false;

    // Estado de Búsqueda Avanzada
    var activeAdvancedFilters = {
        nombre: "",
        fechaDesde: "",
        fechaHasta: "",
        sizeMin: null,
        sizeMax: null,
        etiquetas: [],
        tipos: ["Factura", "Estado de Cuenta", "Declaración", "Contrato", "Reporte", "Otro"]
    };

    document.addEventListener("DOMContentLoaded", function() {
        // Cargar renderizadores iniciales
        updateCategoryCounters();
        renderDocs();

        // Controladores de Sidebar Categorías
        var catBtns = {
            "all": document.getElementById("cat-all"),
            "Ventas": document.getElementById("cat-ventas"),
            "Compras": document.getElementById("cat-compras"),
            "Impuestos": document.getElementById("cat-impuestos"),
            "Cierre": document.getElementById("cat-cierre"),
            "Archivado": document.getElementById("cat-archivados")
        };

        Object.keys(catBtns).forEach(function(key) {
            if (catBtns[key]) {
                catBtns[key].addEventListener("click", function() {
                    // Remover activos
                    Object.values(catBtns).forEach(btn => btn.classList.remove("active"));
                    catBtns[key].classList.add("active");
                    activeCategory = key;
                    cancelSelection(); // Reiniciar selección al cambiar categoría
                    renderDocs();
                });
            }
        });

        // Buscador
        var searchInput = document.getElementById("doc-search");
        if (searchInput) {
            searchInput.addEventListener("input", function() {
                // Al buscar por la barra general, limpiamos búsqueda avanzada
                activeAdvancedFilters.nombre = "";
                renderDocs();
            });
        }

        // Toggle Switch de Vistas (Grilla / Lista)
        var btnViewGrid = document.getElementById("btn-view-grid");
        var btnViewList = document.getElementById("btn-view-list");
        var viewGridContainer = document.getElementById("view-grid-container");
        var viewListContainer = document.getElementById("view-list-container");

        if (btnViewGrid && btnViewList && viewGridContainer && viewListContainer) {
            btnViewGrid.addEventListener("click", function() {
                btnViewGrid.classList.add("active");
                btnViewList.classList.remove("active");
                viewGridContainer.style.display = "block";
                viewListContainer.style.display = "none";
                renderDocs();
            });

            btnViewList.addEventListener("click", function() {
                btnViewList.classList.add("active");
                btnViewGrid.classList.remove("active");
                viewListContainer.style.display = "block";
                viewGridContainer.style.display = "none";
                renderDocs();
            });
        }

        // Filtros Rápidos (Chips)
        var filterChips = document.querySelectorAll(".cta-filter-chip[data-filter]");
        filterChips.forEach(function(chip) {
            chip.addEventListener("click", function() {
                filterChips.forEach(c => c.classList.remove("active"));
                chip.classList.add("active");
                activeFormatFilter = chip.getAttribute("data-filter");
                renderDocs();
            });
        });

        // Modal Upload Eventos
        var btnOpenUpload = document.getElementById("btn-open-upload");
        var btnSaveUpload = document.getElementById("btn-save-upload");

        if (btnOpenUpload) btnOpenUpload.addEventListener("click", openUploadModal);
        if (btnSaveUpload) {
            btnSaveUpload.addEventListener("click", function() {
                var nombre = document.getElementById("up-nombre").value.trim();
                var desc = document.getElementById("up-desc").value.trim();
                var tipo = document.getElementById("up-tipo").value;
                var cat = document.getElementById("up-cat").value;
                var ext = document.getElementById("up-ext").value;
                var tam = parseInt(document.getElementById("up-tam").value) || 120;
                var tagsRaw = document.getElementById("up-tags").value.trim();

                if (!nombre) {
                    alert("Por favor ingrese el nombre del archivo.");
                    return;
                }

                // Add extension if not present
                if (!nombre.toLowerCase().endsWith("." + ext)) {
                    nombre = nombre + "." + ext;
                }

                var tags = tagsRaw ? tagsRaw.split(",").map(t => t.trim()) : [cat];

                // Crear Documento
                var newId = dbDocs.length > 0 ? Math.max(...dbDocs.map(d => d.id)) + 1 : 1;
                var today = new Date().toISOString().split('T')[0];

                var newDoc = {
                    id: newId,
                    nombre: nombre,
                    descripcion: desc || "Sin descripción provista.",
                    tipoDoc: tipo,
                    categoria: cat,
                    fechaSubida: today,
                    tamanoKB: tam,
                    extension: ext,
                    subidoPor: "Luis Torres",
                    etiquetas: tags,
                    estado: "Activo"
                };

                dbDocs.push(newDoc);
                closeUploadModal();
                updateCategoryCounters();
                renderDocs();
                showToast("Documento Subido", `"${nombre}" se ha incorporado al repositorio contable.`, "success");
            });
        }
    });

    // --- MOTOR CENTRAL DE FILTRADO Y RENDERIZACIÓN ---
    function renderDocs() {
        var searchInput = document.getElementById("doc-search");
        var searchVal = searchInput ? searchInput.value.toLowerCase().trim() : "";
        var filtered = [...dbDocs];

        // 1. Filtrar por Sidebar Categoría
        if (activeCategory === "Archivado") {
            filtered = filtered.filter(d => d.estado === "Archivado");
        } else {
            // Si no es archivado, solo mostrar activos
            filtered = filtered.filter(d => d.estado === "Activo");
            if (activeCategory !== "all") {
                filtered = filtered.filter(d => d.categoria === activeCategory);
            }
        }

        // 2. Filtrar por Filtros Rápidos (Chips)
        if (activeFormatFilter === "pdf") filtered = filtered.filter(d => d.extension === "pdf");
        if (activeFormatFilter === "xlsx") filtered = filtered.filter(d => d.extension === "xlsx");
        if (activeFormatFilter === "xml") filtered = filtered.filter(d => d.extension === "xml");
        if (activeFormatFilter === "recent") {
            filtered = filtered.filter(d => d.fechaSubida.startsWith("2026-05") || d.fechaSubida.startsWith("2026-06"));
        }

        // 3. Filtrar por Búsqueda de Texto General (Barra Principal)
        if (searchVal !== "") {
            filtered = filtered.filter(function(d) {
                var matchName = d.nombre.toLowerCase().includes(searchVal);
                var matchTags = d.etiquetas.some(tag => tag.toLowerCase().includes(searchVal));
                return matchName || matchTags;
            });
        }

        // 4. Filtrar por Búsqueda Avanzada (si está activa/formulada)
        if (activeAdvancedFilters.nombre !== "") {
            filtered = filtered.filter(d => d.nombre.toLowerCase().includes(activeAdvancedFilters.nombre.toLowerCase()));
        }
        if (activeAdvancedFilters.fechaDesde !== "") {
            filtered = filtered.filter(d => d.fechaSubida >= activeAdvancedFilters.fechaDesde);
        }
        if (activeAdvancedFilters.fechaHasta !== "") {
            filtered = filtered.filter(d => d.fechaSubida <= activeAdvancedFilters.fechaHasta);
        }
        if (activeAdvancedFilters.sizeMin !== null) {
            filtered = filtered.filter(d => d.tamanoKB >= activeAdvancedFilters.sizeMin);
        }
        if (activeAdvancedFilters.sizeMax !== null) {
            filtered = filtered.filter(d => d.tamanoKB <= activeAdvancedFilters.sizeMax);
        }
        if (activeAdvancedFilters.etiquetas.length > 0) {
            filtered = filtered.filter(d => {
                return activeAdvancedFilters.etiquetas.some(tag => d.etiquetas.some(t => t.toLowerCase().includes(tag.toLowerCase())));
            });
        }
        // Filtrado por Checkboxes de Tipo
        filtered = filtered.filter(d => activeAdvancedFilters.tipos.includes(d.tipoDoc));

        // 5. Filtrar por Etiquetas seleccionadas client-side
        var breadcrumb = document.getElementById("active-tag-breadcrumb");
        if (activeTagFilter) {
            filtered = filtered.filter(d => d.etiquetas.includes(activeTagFilter));
            if (breadcrumb) {
                breadcrumb.style.display = "flex";
                document.getElementById("active-tag-name").textContent = "#" + activeTagFilter;
            }
        } else {
            if (breadcrumb) breadcrumb.style.display = "none";
        }

        // 6. Ordenamiento en Tiempo Real
        var sortVal = document.getElementById("doc-sort").value;
        if (sortVal === "recent") {
            filtered.sort((a, b) => new Date(b.fechaSubida) - new Date(a.fechaSubida) || b.id - a.id);
        } else if (sortVal === "oldest") {
            filtered.sort((a, b) => new Date(a.fechaSubida) - new Date(b.fechaSubida) || a.id - b.id);
        } else if (sortVal === "name") {
            filtered.sort((a, b) => a.nombre.localeCompare(b.nombre));
        } else if (sortVal === "size") {
            filtered.sort((a, b) => b.tamanoKB - a.tamanoKB);
        }

        // Actualizar contador del grid
        var totalVisibles = filtered.length;
        var totalDb = dbDocs.filter(d => activeCategory === "Archivado" ? d.estado === "Archivado" : d.estado === "Activo").length;
        document.getElementById("grid-visible-count").textContent = `${totalVisibles} de ${totalDb} mostrados`;

        // Renderizado en Grilla
        renderGridView(filtered);

        // Renderizado en Lista
        renderListView(filtered);

        // Actualizar barra de acciones flotante por si cambiaron los visibles
        updateFloatingActionBar();
    }

    // --- VISTA GRILLA ---
    function renderGridView(filtered) {
        var gridContainer = document.getElementById("doc-grid");
        gridContainer.innerHTML = "";
        
        if (filtered.length === 0) {
            gridContainer.innerHTML = `
                <div style="grid-column: 1 / -1; text-align: center; padding: 48px; background: #ffffff; border: 1px solid var(--cta-border); border-radius: var(--cta-radius); color: var(--cta-text-muted);">
                    <span style="font-size: 36px; display: block; margin-bottom: 8px;">📂</span>
                    <span style="font-style: italic; font-size:13.5px;">No se encontraron documentos contables con los filtros seleccionados.</span>
                </div>`;
        } else {
            filtered.forEach(function(d) {
                var dateStr = stringJoinReverse(d.fechaSubida);
                var sizeStr = formatKB(d.tamanoKB);
                var iconSvg = getLargeIconHtml(d.extension);
                var isChecked = selectedDocIds.has(d.id);

                var cardHtml = `
                    <div class="cta-doc-card" onclick="openPreviewDrawer(${d.id})" style="position: relative;">
                        
                        <!-- Checkbox Multi-Selección -->
                        <div style="position: absolute; top: 12px; left: 12px; z-index: 15;" onclick="event.stopPropagation();">
                            <input type="checkbox" class="doc-selector-checkbox" data-id="${d.id}" ${isChecked ? 'checked' : ''} onclick="handleCheckboxClick(event, ${d.id})" style="width: 17px; height: 17px; cursor: pointer; accent-color: var(--cta-primary);" />
                        </div>

                        <!-- Menú de 3 puntos -->
                        <div style="position: absolute; top: 12px; right: 12px; z-index: 15;" onclick="event.stopPropagation();">
