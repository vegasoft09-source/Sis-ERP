                                <button class="cta-dropdown-item" onclick="downloadDoc(${d.id})">Descargar</button>
                                <button class="cta-dropdown-item" onclick="archiveDoc(event, ${d.id})" style="color: #d97706;">${d.estado === 'Activo' ? 'Archivar' : 'Restaurar'}</button>
