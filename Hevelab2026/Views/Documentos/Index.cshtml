@model IEnumerable<DocumentoContable>
@{
    ViewData["Title"] = "Documentos Contables";

    var documentos = Model;
}

<!-- Contenedor Principal de la Vista -->
<div class="cta-documentos-container" style="display: flex; gap: 24px; min-height: calc(100vh - 160px); animation: ctaFadeIn 300ms ease-out; position: relative;">
    
    <!-- 2. Panel de Categorías (Sidebar Izquierdo de la vista) -->
    <div class="cta-doc-sidebar" style="width: 260px; background: #ffffff; border: 1px solid var(--cta-border); border-radius: var(--cta-radius); padding: 20px 16px; display: flex; flex-direction: column; gap: 6px; flex-shrink: 0; box-shadow: var(--cta-shadow);">
        <h3 style="font-size: 11px; font-weight: 700; color: var(--cta-text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px; padding-left: 8px;">Categorías</h3>
        <button id="cat-all" class="cta-cat-btn active">
            <span>📁 Todos los documentos</span>
            <span class="cta-cat-count" id="count-all">0</span>
        </button>
        <button id="cat-ventas" class="cta-cat-btn">
            <span>📁 Ventas</span>
            <span class="cta-cat-count" id="count-ventas">0</span>
        </button>
        <button id="cat-compras" class="cta-cat-btn">
            <span>📁 Compras</span>
            <span class="cta-cat-count" id="count-compras">0</span>
        </button>
        <button id="cat-impuestos" class="cta-cat-btn">
            <span>📁 Impuestos / SUNAT</span>
            <span class="cta-cat-count" id="count-impuestos">0</span>
        </button>
        <button id="cat-cierre" class="cta-cat-btn">
            <span>📁 Cierre Contable</span>
            <span class="cta-cat-count" id="count-cierre">0</span>
        </button>
        <button id="cat-archivados" class="cta-cat-btn">
            <span>📁 Archivados</span>
            <span class="cta-cat-count" id="count-archivados">0</span>
        </button>
    </div>

    <!-- Panel de Contenido Derecho -->
    <div class="cta-doc-content" style="flex: 1; display: flex; flex-direction: column; gap: 20px; min-width: 0;">
        
        <!-- 1. Barra Superior -->
        <div style="background: #ffffff; border: 1px solid var(--cta-border); border-radius: var(--cta-radius); padding: 20px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; box-shadow: var(--cta-shadow);">
            <div>
                <h1 style="font-size: 22px; font-weight: 700; color: var(--cta-text-primary); margin: 0; display: flex; align-items: center; gap: 8px;">
                    <svg viewBox="0 0 24 24" style="width: 24px; height: 24px; fill: none; stroke: var(--cta-primary); stroke-width: 2.5;">
                        <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
                    </svg>
                    Documentos Contables
                </h1>
                <p style="font-size: 13px; color: var(--cta-text-secondary); margin: 4px 0 0 0;">Repositorio y gestor digital de comprobantes, balances y archivos contables de la empresa.</p>
            </div>
            
            <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap;">
                <!-- Buscador Principal -->
                <div style="position: relative;">
                    <input type="text" id="doc-search" placeholder="Buscar por nombre o etiqueta..." style="padding: 8px 12px 8px 32px; border: 1px solid var(--cta-border); border-radius: 6px; font-size: 13px; outline: none; width: 240px; color: var(--cta-text-primary); transition: border-color var(--cta-transition);" onfocus="this.style.borderColor='var(--cta-primary)'" onblur="this.style.borderColor='var(--cta-border)'" />
                    <svg viewBox="0 0 24 24" style="width: 16px; height: 16px; stroke: var(--cta-text-muted); stroke-width: 2.5; fill: none; position: absolute; left: 10px; top: 10px;">
                        <circle cx="11" cy="11" r="8"></circle>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                    </svg>
                </div>

                <!-- Botón Búsqueda Avanzada -->
                <button id="btn-adv-search" class="cta-filter-chip" style="border: 1px solid var(--cta-primary); color: var(--cta-primary); display: flex; align-items: center; gap: 6px; background: transparent; cursor: pointer; padding: 8px 12px; border-radius: 9999px; font-size: 12px; font-weight: 600;" onclick="toggleAdvancedSearch()">
                    <svg viewBox="0 0 24 24" style="width: 13px; height: 13px; fill: none; stroke: currentColor; stroke-width: 2.5;">
                        <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
                    </svg>
                    Filtros Avanzados
                </button>
                
                <!-- Selector de Ordenamiento -->
                <div style="display: flex; align-items: center; gap: 6px;">
                    <label for="doc-sort" style="font-size: 12.5px; color: var(--cta-text-secondary); font-weight: 500;">Ordenar:</label>
                    <select id="doc-sort" onchange="handleSortChange()" style="padding: 7px 10px; border: 1px solid var(--cta-border); background: #ffffff; border-radius: 6px; font-size: 13px; color: var(--cta-text-primary); outline: none; cursor: pointer;">
                        <option value="recent">Más recientes</option>
                        <option value="oldest">Más antiguos</option>
                        <option value="name">Nombre A-Z</option>
                        <option value="size">Mayor tamaño</option>
                    </select>
                </div>

                <!-- Switch / Toggle Vista -->
                <div style="display: flex; border: 1px solid var(--cta-border); border-radius: 6px; overflow: hidden; background: #ffffff;">
                    <button id="btn-view-grid" class="cta-toggle-btn active" title="Vista Grilla">
                        <svg viewBox="0 0 24 24" style="width: 16px; height: 16px; fill: none; stroke: currentColor; stroke-width: 2.5;">
                            <rect x="3" y="3" width="7" height="7"></rect>
                            <rect x="14" y="3" width="7" height="7"></rect>
                            <rect x="14" y="14" width="7" height="7"></rect>
                            <rect x="3" y="14" width="7" height="7"></rect>
                        </svg>
                    </button>
                    <button id="btn-view-list" class="cta-toggle-btn" title="Vista Lista">
                        <svg viewBox="0 0 24 24" style="width: 16px; height: 16px; fill: none; stroke: currentColor; stroke-width: 2.5;">
                            <line x1="8" y1="6" x2="21" y2="6"></line>
                            <line x1="8" y1="12" x2="21" y2="12"></line>
                            <line x1="8" y1="18" x2="21" y2="18"></line>
                            <line x1="3" y1="6" x2="3.01" y2="6"></line>
                            <line x1="3" y1="12" x2="3.01" y2="12"></line>
                            <line x1="3" y1="18" x2="3.01" y2="18"></line>
                        </svg>
                    </button>
                </div>
                
                <!-- Botón Subir -->
                <button id="btn-open-upload" style="background: var(--cta-primary); color: #ffffff; border: none; padding: 9px 16px; border-radius: 6px; font-size: 13px; font-weight: 600; cursor: pointer; transition: background var(--cta-transition); display: flex; align-items: center; gap: 6px;" onmouseover="this.style.background='var(--cta-primary-hover)'" onmouseout="this.style.background='var(--cta-primary)'">
                    <svg viewBox="0 0 24 24" style="width:16px; height:16px; fill:none; stroke:currentColor; stroke-width:2.5; stroke-linecap:round; stroke-linejoin:round;">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                        <polyline points="17 8 12 3 7 8"></polyline>
                        <line x1="12" y1="3" x2="12" y2="15"></line>
                    </svg>
                    Subir Documento
                </button>
            </div>
        </div>

        <!-- 3. Panel de Búsqueda Avanzada (Expandible) -->
        <div id="adv-search-panel" style="display: none; background: #ffffff; border: 1px solid var(--cta-border); border-radius: var(--cta-radius); padding: 20px; box-shadow: var(--cta-shadow); animation: ctaFadeIn 200ms ease-out;">
            <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--cta-border); padding-bottom: 10px; margin-bottom: 16px;">
                <h4 style="font-size: 14px; font-weight: 700; color: var(--cta-text-primary); margin: 0;">Filtros de Búsqueda Avanzada</h4>
                <button onclick="toggleAdvancedSearch()" style="background:none; border:none; font-size:18px; color:var(--cta-text-muted); cursor:pointer;">&times;</button>
            </div>
            
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 16px;">
                <!-- Nombre contiene -->
                <div>
                    <label style="display: block; font-size: 12px; font-weight: 600; color: var(--cta-text-secondary); margin-bottom: 4px;">Nombre del Documento</label>
                    <input type="text" id="adv-nombre" placeholder="Nombre contiene..." style="width: 100%; padding: 8px 10px; border: 1px solid var(--cta-border); border-radius: 6px; outline: none; font-size: 13px;" />
                </div>
                
                <!-- Rango de fechas -->
                <div>
                    <label style="display: block; font-size: 12px; font-weight: 600; color: var(--cta-text-secondary); margin-bottom: 4px;">Fecha Desde</label>
                    <input type="date" id="adv-fecha-desde" style="width: 100%; padding: 7px 10px; border: 1px solid var(--cta-border); border-radius: 6px; outline: none; font-size: 13px;" />
                </div>
                <div>
                    <label style="display: block; font-size: 12px; font-weight: 600; color: var(--cta-text-secondary); margin-bottom: 4px;">Fecha Hasta</label>
                    <input type="date" id="adv-fecha-hasta" style="width: 100%; padding: 7px 10px; border: 1px solid var(--cta-border); border-radius: 6px; outline: none; font-size: 13px;" />
                </div>
                
                <!-- Rango de tamaño (KB) -->
                <div>
                    <label style="display: block; font-size: 12px; font-weight: 600; color: var(--cta-text-secondary); margin-bottom: 4px;">Tamaño Mín (KB)</label>
                    <input type="number" id="adv-tam-min" placeholder="0" style="width: 100%; padding: 8px 10px; border: 1px solid var(--cta-border); border-radius: 6px; outline: none; font-size: 13px;" />
                </div>
                <div>
                    <label style="display: block; font-size: 12px; font-weight: 600; color: var(--cta-text-secondary); margin-bottom: 4px;">Tamaño Máx (KB)</label>
                    <input type="number" id="adv-tam-max" placeholder="ej: 10000" style="width: 100%; padding: 8px 10px; border: 1px solid var(--cta-border); border-radius: 6px; outline: none; font-size: 13px;" />
                </div>
                
                <!-- Etiquetas -->
                <div>
                    <label style="display: block; font-size: 12px; font-weight: 600; color: var(--cta-text-secondary); margin-bottom: 4px;">Etiquetas (separadas por comas)</label>
                    <input type="text" id="adv-etiquetas" placeholder="ej: Mayo, SUNAT, XML" style="width: 100%; padding: 8px 10px; border: 1px solid var(--cta-border); border-radius: 6px; outline: none; font-size: 13px;" />
                </div>
            </div>
            
            <!-- Tipo de documento Checkboxes -->
            <div style="margin-bottom: 16px; border-top: 1px dashed var(--cta-border); padding-top: 12px;">
                <label style="display: block; font-size: 12px; font-weight: 600; color: var(--cta-text-secondary); margin-bottom: 8px;">Tipos de Documento</label>
                <div style="display: flex; gap: 16px; flex-wrap: wrap;">
                    <label style="display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--cta-text-secondary); cursor: pointer;">
                        <input type="checkbox" class="adv-tipo-check" value="Factura" checked /> Facturas
                    </label>
                    <label style="display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--cta-text-secondary); cursor: pointer;">
                        <input type="checkbox" class="adv-tipo-check" value="Estado de Cuenta" checked /> Estados de Cuenta
                    </label>
                    <label style="display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--cta-text-secondary); cursor: pointer;">
                        <input type="checkbox" class="adv-tipo-check" value="Declaración" checked /> Declaraciones
                    </label>
                    <label style="display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--cta-text-secondary); cursor: pointer;">
                        <input type="checkbox" class="adv-tipo-check" value="Contrato" checked /> Contratos
                    </label>
                    <label style="display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--cta-text-secondary); cursor: pointer;">
                        <input type="checkbox" class="adv-tipo-check" value="Reporte" checked /> Reportes
                    </label>
                    <label style="display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--cta-text-secondary); cursor: pointer;">
                        <input type="checkbox" class="adv-tipo-check" value="Otro" checked /> Otros
                    </label>
                </div>
            </div>
            
            <!-- Botones de Acción -->
            <div style="display: flex; justify-content: flex-end; gap: 10px; border-top: 1px solid var(--cta-border); padding-top: 12px;">
                <button onclick="clearAdvancedFilters()" style="background: #ffffff; border: 1px solid var(--cta-border); color: var(--cta-text-secondary); padding: 8px 16px; border-radius: 6px; font-size: 12.5px; font-weight: 600; cursor: pointer;">Limpiar Filtros</button>
                <button onclick="applyAdvancedFilters()" style="background: var(--cta-primary); color: #ffffff; border: none; padding: 8px 16px; border-radius: 6px; font-size: 12.5px; font-weight: 600; cursor: pointer; transition: background var(--cta-transition);" onmouseover="this.style.background='var(--cta-primary-hover)'" onmouseout="this.style.background='var(--cta-primary)'">Aplicar Filtros</button>
            </div>
        </div>

        <!-- 2. Zona de Drag & Drop (Collapsible Card) -->
        <div class="cta-drag-drop-card" id="cta-drag-drop-card" style="background: #ffffff; border: 1px solid var(--cta-border); border-radius: var(--cta-radius); padding: 16px; box-shadow: var(--cta-shadow); transition: all var(--cta-transition);">
            <div style="display: flex; justify-content: space-between; align-items: center; cursor: pointer; user-select: none;" onclick="toggleDragDropZone()">
                <div style="display: flex; align-items: center; gap: 10px;">
                    <svg viewBox="0 0 24 24" style="width: 20px; height: 20px; fill: none; stroke: var(--cta-primary); stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round;">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                        <polyline points="17 8 12 3 7 8"></polyline>
                        <line x1="12" y1="3" x2="12" y2="15"></line>
                    </svg>
                    <span style="font-weight: 600; font-size: 13.5px; color: var(--cta-text-primary);">Zona de Carga Rápida y Drag & Drop</span>
                </div>
                <span id="drag-drop-toggle-indicator" style="font-size: 12px; color: var(--cta-text-muted); font-weight: 600;">▼ Colapsar</span>
            </div>
            
            <div id="drag-drop-collapsible-zone" style="max-height: 200px; transition: max-height 0.3s cubic-bezier(0, 1, 0, 1); overflow: hidden; margin-top: 14px;">
                <div id="drop-zone" style="border: 2px dashed var(--cta-border); border-radius: 8px; padding: 24px; text-align: center; background: #f8fafc; cursor: pointer; transition: all var(--cta-transition);" ondragover="handleDragOver(event)" ondragleave="handleDragLeave(event)" ondrop="handleDrop(event)" onclick="triggerFileInput()">
                    <span style="font-size: 28px; display: block; margin-bottom: 6px;">☁️</span>
                    <p style="font-size: 13px; font-weight: 600; color: var(--cta-text-secondary); margin: 0;">Arrastra tus documentos contables aquí o haz clic para seleccionar</p>
                    <p style="font-size: 11px; color: var(--cta-text-muted); margin: 4px 0 0 0;">Formatos admitidos: PDF, XLSX, XML. Carga simulada instantánea.</p>
                    <input type="file" id="file-input-hidden" style="display: none;" multiple onchange="handleFileSelect(event)" />
                </div>
            </div>
        </div>

        <!-- 5. Filtros Rápidos (Chips) & Tag Breadcrumb -->
        <div style="display: flex; flex-direction: column; gap: 12px; background: #ffffff; border: 1px solid var(--cta-border); border-radius: var(--cta-radius); padding: 12px 18px; box-shadow: var(--cta-shadow);">
            <div style="display: flex; gap: 8px; flex-wrap: wrap; align-items: center;">
                <span style="font-size: 12px; font-weight: 600; color: var(--cta-text-secondary); margin-right: 4px;">Formato rápido:</span>
                <button class="cta-filter-chip active" data-filter="all" id="chip-filter-all">Todos los formatos</button>
                <button class="cta-filter-chip" data-filter="pdf" id="chip-filter-pdf">PDF</button>
                <button class="cta-filter-chip" data-filter="xlsx" id="chip-filter-xlsx">Excel</button>
                <button class="cta-filter-chip" data-filter="xml" id="chip-filter-xml">XML</button>
                <button class="cta-filter-chip" data-filter="recent" id="chip-filter-recent">Recientes</button>
            </div>

            <!-- Breadcrumb de Etiqueta Activa -->
            <div id="active-tag-breadcrumb" style="display: none; align-items: center; justify-content: space-between; background: var(--cta-primary-soft); border: 1px solid rgba(59,93,219,0.15); padding: 8px 12px; border-radius: 6px; font-size: 12.5px; color: var(--cta-primary); animation: ctaFadeIn 200ms ease-out;">
                <span>Mostrando documentos con la etiqueta: <strong id="active-tag-name"></strong></span>
                <button onclick="clearTagFilter()" style="background: none; border: none; font-size: 16px; font-weight: bold; color: var(--cta-primary); cursor: pointer; display: flex; align-items: center; justify-content: center; padding: 0 4px; border-radius: 4px; line-height: 1;">&times;</button>
            </div>
        </div>

        <!-- 3. Vista Grilla (Por defecto) -->
        <div id="view-grid-container" style="display: block;">
            <!-- Cabecera de Grilla con Check All -->
            <div style="display: flex; justify-content: space-between; align-items: center; padding: 4px 8px 12px 8px; border-bottom: 1px solid var(--cta-border); margin-bottom: 12px;">
                <label style="display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--cta-text-secondary); cursor: pointer; font-weight: 500;">
                    <input type="checkbox" id="check-all-docs-grid" onclick="toggleSelectAll(this)" style="width: 15px; height: 15px; cursor: pointer; accent-color: var(--cta-primary);" />
                    Seleccionar todos los visibles
                </label>
                <span id="grid-visible-count" style="font-size: 12px; color: var(--cta-text-muted); font-weight: 500;">0 de 0 mostrados</span>
            </div>
            <div id="doc-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 20px;">
                <!-- Dinámico -->
            </div>
        </div>

        <!-- 4. Vista Lista -->
        <div id="view-list-container" style="display: none;">
            <div style="background: #ffffff; border: 1px solid var(--cta-border); border-radius: var(--cta-radius); overflow: hidden; box-shadow: var(--cta-shadow);">
                <div style="overflow-x: auto; width: 100%;">
                    <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 13px; min-width: 900px;">
                        <thead>
                            <tr style="background: #f8fafc; border-bottom: 1px solid var(--cta-border); color: var(--cta-text-secondary); font-weight: 600;">
                                <th style="padding: 12px 16px; width: 45px; text-align: center;">
                                    <input type="checkbox" id="check-all-docs" onclick="toggleSelectAll(this)" style="width: 15px; height: 15px; cursor: pointer; accent-color: var(--cta-primary);" />
                                </th>
                                <th style="padding: 12px 16px; width: 60px; text-align: center;">Ícono</th>
                                <th style="padding: 12px 16px;">Nombre del Documento</th>
                                <th style="padding: 12px 16px; width: 130px;">Tipo</th>
                                <th style="padding: 12px 16px; width: 130px;">Categoría</th>
                                <th style="padding: 12px 16px; width: 110px;">Subida</th>
                                <th style="padding: 12px 16px; width: 90px; text-align: right;">Tamaño</th>
                                <th style="padding: 12px 16px; width: 95px; text-align: center;">Estado</th>
                                <th style="padding: 12px 16px; width: 120px; text-align: center;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="doc-list-body" style="color: var(--cta-text-primary);">
                            <!-- Dinámico -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- 1. PANEL DE PREVIEW (Drawer Lateral Derecho Deslizable) -->
<div id="cta-drawer-overlay" class="cta-drawer-overlay" onclick="closePreviewDrawer()"></div>
<div id="cta-preview-drawer" class="cta-preview-drawer">
    <div class="cta-drawer-header">
        <div style="display: flex; align-items: center; gap: 8px;">
            <svg viewBox="0 0 24 24" style="width: 20px; height: 20px; fill: none; stroke: var(--cta-primary); stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round;">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                <polyline points="14 2 14 8 20 8"></polyline>
            </svg>
            <span style="font-weight: 700; font-size: 14.5px; color: var(--cta-text-primary);">Previsualización de Documento</span>
        </div>
        <button onclick="closePreviewDrawer()" class="cta-drawer-close-btn">&times;</button>
    </div>
    <div class="cta-drawer-body" id="drawer-body-content">
        <!-- Contenido Dinámico inyectado por JS -->
    </div>
    <div class="cta-drawer-footer" id="drawer-footer-actions">
        <!-- Botones Dinámicos inyectados por JS -->
    </div>
</div>

<!-- 5. Barra de Acciones Flotante de Selección Múltiple (Indigo oscuro y fixed bottom) -->
<div id="cta-floating-actions-bar" class="cta-floating-actions-bar">
    <div style="display: flex; align-items: center; gap: 10px;">
        <span style="font-size: 18px;">📋</span>
        <span style="font-size: 13.5px;"><strong id="selected-count" style="font-size: 15px; color: #a5b4fc; font-weight: 700;">0</strong> documentos seleccionados</span>
    </div>
    <div style="display: flex; gap: 10px; align-items: center;">
        <button class="cta-action-btn-danger" onclick="archiveSelected()">Archivar Seleccionados</button>
        <button class="cta-action-btn-primary" onclick="downloadZipSelected()">Descargar ZIP</button>
        <button class="cta-action-btn-secondary" onclick="cancelSelection()">Cancelar</button>
    </div>
</div>

<!-- Modal Mock Upload -->
<div id="cta-upload-modal" style="position: fixed; inset: 0; background: rgba(30, 41, 59, 0.4); backdrop-filter: blur(4px); z-index: 2000; display: none; align-items: center; justify-content: center; opacity: 0; transition: opacity var(--cta-transition);">
    <div id="cta-upload-card" style="background: #ffffff; border-radius: var(--cta-radius); width: 100%; max-width: 500px; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1); transform: scale(0.95); transition: transform var(--cta-transition); display: flex; flex-direction: column;">
        <div style="padding: 18px 24px; border-bottom: 1px solid var(--cta-border); display: flex; justify-content: space-between; align-items: center; background: #f8fafc;">
            <h3 style="font-size: 15px; font-weight: 700; color: var(--cta-text-primary); margin: 0;">Subir Nuevo Documento Contable</h3>
            <button onclick="closeUploadModal()" style="background: none; border: none; font-size: 22px; color: var(--cta-text-muted); cursor: pointer;">&times;</button>
        </div>
        
        <div style="padding: 24px; display: flex; flex-direction: column; gap: 16px; font-size: 13px;">
            <div>
                <label for="up-nombre" style="display: block; font-weight: 600; margin-bottom: 6px; color: var(--cta-text-secondary);">Nombre del Archivo</label>
                <input type="text" id="up-nombre" placeholder="ej: Planilla_Enero.pdf" style="width:100%; padding:8px 10px; border:1px solid var(--cta-border); border-radius:6px; outline:none; font-size:13px;" />
            </div>
            
            <div>
                <label for="up-desc" style="display: block; font-weight: 600; margin-bottom: 6px; color: var(--cta-text-secondary);">Descripción</label>
                <textarea id="up-desc" placeholder="Describa brevemente el contenido de este archivo..." style="width:100%; padding:8px 10px; border:1px solid var(--cta-border); border-radius:6px; outline:none; font-size:13px; height:60px; resize:none;"></textarea>
            </div>
            
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                <div>
                    <label for="up-tipo" style="display: block; font-weight: 600; margin-bottom: 6px; color: var(--cta-text-secondary);">Tipo de Documento</label>
                    <select id="up-tipo" style="width:100%; padding:8px 10px; border:1px solid var(--cta-border); border-radius:6px; outline:none; font-size:13px;">
                        <option value="Factura">Factura</option>
                        <option value="Estado de Cuenta">Estado de Cuenta</option>
                        <option value="Declaración">Declaración</option>
                        <option value="Contrato">Contrato</option>
                        <option value="Reporte">Reporte</option>
                        <option value="Otro">Otro</option>
                    </select>
                </div>
                <div>
                    <label for="up-cat" style="display: block; font-weight: 600; margin-bottom: 6px; color: var(--cta-text-secondary);">Categoría</label>
                    <select id="up-cat" style="width:100%; padding:8px 10px; border:1px solid var(--cta-border); border-radius:6px; outline:none; font-size:13px;">
                        <option value="Ventas">Ventas</option>
                        <option value="Compras">Compras</option>
                        <option value="Impuestos">Impuestos / SUNAT</option>
                        <option value="Cierre">Cierre Contable</option>
                    </select>
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                <div>
                    <label for="up-ext" style="display: block; font-weight: 600; margin-bottom: 6px; color: var(--cta-text-secondary);">Extensión (Formato)</label>
                    <select id="up-ext" style="width:100%; padding:8px 10px; border:1px solid var(--cta-border); border-radius:6px; outline:none; font-size:13px;">
                        <option value="pdf">PDF (📄)</option>
                        <option value="xlsx">Excel (📊)</option>
                        <option value="xml">XML (📋)</option>
                    </select>
                </div>
                <div>
                    <label for="up-tam" style="display: block; font-weight: 600; margin-bottom: 6px; color: var(--cta-text-secondary);">Tamaño (KB)</label>
                    <input type="number" id="up-tam" value="250" style="width:100%; padding:8px 10px; border:1px solid var(--cta-border); border-radius:6px; outline:none; font-size:13px;" />
                </div>
            </div>

            <div>
                <label for="up-tags" style="display: block; font-weight: 600; margin-bottom: 6px; color: var(--cta-text-secondary);">Etiquetas (Separadas por comas)</label>
                <input type="text" id="up-tags" placeholder="ej: Impuestos, Anual, SUNAT" style="width:100%; padding:8px 10px; border:1px solid var(--cta-border); border-radius:6px; outline:none; font-size:13px;" />
            </div>
        </div>
        
        <div style="padding: 16px 24px; border-top: 1px solid var(--cta-border); background: #f8fafc; display: flex; justify-content: flex-end; gap: 12px;">
            <button id="btn-save-upload" style="background: var(--cta-primary); color: #ffffff; border: none; padding: 8px 16px; border-radius: 6px; font-weight: 600; cursor: pointer; transition: background var(--cta-transition);" onmouseover="this.style.background='var(--cta-primary-hover)'" onmouseout="this.style.background='var(--cta-primary)'">Subir Documento</button>
            <button onclick="closeUploadModal()" style="background: #ffffff; border: 1px solid var(--cta-border); color: var(--cta-text-secondary); padding: 8px 16px; border-radius: 6px; font-weight: 600; cursor: pointer;">Cancelar</button>
        </div>
    </div>
</div>

<!-- Estilos Locales CSS -->
