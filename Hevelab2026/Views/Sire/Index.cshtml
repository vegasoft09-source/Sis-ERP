@model SireViewModel
@{
    ViewData["Title"] = "SIRE SUNAT";

    var ventasRV = Model.VentasRV;
    var comprasRC = Model.ComprasRC;
}
}

<div class="cta-module-card" style="background: #ffffff; border: 1px solid var(--cta-border); border-radius: var(--cta-radius); box-shadow: var(--cta-shadow); padding: 24px; animation: ctaFadeIn 300ms ease-out;">
    
    <!-- 1. Encabezado y Selector de Período -->
    <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--cta-border); padding-bottom: 16px; margin-bottom: 24px; flex-wrap: wrap; gap: 16px;">
        <div style="display: flex; align-items: center; gap: 12px;">
            <!-- Icono SUNAT / SIRE -->
            <div style="color: #d97706; display: flex; align-items: center; justify-content: center; background: rgba(217, 119, 6, 0.08); width: 42px; height: 42px; border-radius: 8px;">
                <svg viewBox="0 0 24 24" style="width: 22px; height: 22px; fill: none; stroke: currentColor; stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round;">
                    <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path>
                </svg>
            </div>
            <div>
                <h1 style="font-size: 20px; font-weight: 700; color: var(--cta-text-primary); margin: 0;">SIRE — Registros Electrónicos</h1>
                <div style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
                    <p style="font-size: 12.5px; color: var(--cta-text-secondary); margin: 2px 0 0 0;">Sistema Integrado de Registros Electrónicos (SUNAT - Perú).</p>
                    <span style="color: var(--cta-text-muted); margin-top: 2px;">·</span>
                    <!-- Diagnóstico del Período -->
                    <div id="validaciones-resumen" style="font-size: 11.5px; font-weight: 600; color: var(--cta-text-secondary); margin-top: 2px; display: flex; gap: 8px; align-items: center;">
                        <span id="count-valid" style="color: #10b981; display: flex; align-items: center; gap: 4px;">
                            <span style="display:inline-block; width:6px; height:6px; border-radius:50%; background:#10b981;"></span> 0 Válidos
                        </span>
                        <span style="color: var(--cta-text-muted);">·</span>
                        <span id="count-warning" style="color: #d97706; display: flex; align-items: center; gap: 4px;">
                            <span style="display:inline-block; width:6px; height:6px; border-radius:50%; background:#d97706;"></span> 0 Con Obs.
                        </span>
                        <span style="color: var(--cta-text-muted);">·</span>
                        <span id="count-error" style="color: #ef4444; display: flex; align-items: center; gap: 4px;">
                            <span style="display:inline-block; width:6px; height:6px; border-radius:50%; background:#ef4444;"></span> 0 Con Error
                        </span>
                    </div>
                </div>
            </div>
        </div>
        
        <div>
            <!-- Estado de Envío -->
            <span id="badge-estado" style="background: rgba(217, 119, 6, 0.12); color: #d97706; border: 1px solid rgba(217, 119, 6, 0.2); padding: 6px 14px; border-radius: 9999px; font-size: 12.5px; font-weight: 600; transition: all var(--cta-transition);">
                Pendiente de envío
            </span>
        </div>
    </div>

    <!-- Barra de Selección General -->
    <div style="background: #fffbf7; border: 1px solid #fcd34d; border-radius: var(--cta-radius); padding: 16px; margin-bottom: 24px; display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 16px; align-items: flex-end;">
        <div>
            <label for="select-ruc" style="display: block; font-size: 12px; font-weight: 600; color: var(--cta-text-secondary); margin-bottom: 6px;">Empresa / RUC Emisor</label>
            <select id="select-ruc" style="width: 100%; padding: 8px 10px; border: 1px solid var(--cta-border); background: #ffffff; border-radius: 6px; font-size: 13px; color: var(--cta-text-primary); outline: none;">
                <option value="20609876541">20609876541 - HEVELAB S.A.C.</option>
            </select>
        </div>

        <div>
            <label for="select-periodo" style="display: block; font-size: 12px; font-weight: 600; color: var(--cta-text-secondary); margin-bottom: 6px;">Período Tributario</label>
            <div style="display: flex; align-items: center; gap: 4px;">
                <button id="btn-prev-periodo" style="background: #ffffff; border: 1px solid var(--cta-border); padding: 8px 12px; border-radius: 6px; cursor: pointer; color: var(--cta-text-secondary); font-size: 12px; font-weight: 700; transition: all var(--cta-transition);" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='#ffffff'" title="Período anterior">
                    &lsaquo;
                </button>
                <select id="select-periodo" style="flex: 1; padding: 8px 10px; border: 1px solid var(--cta-border); background: #ffffff; border-radius: 6px; font-size: 13px; color: var(--cta-text-primary); outline: none; text-align: center;">
                    <option value="2024-04">Abril 2024</option>
                    <option value="2024-05" selected>Mayo 2024</option>
                    <option value="2024-06">Junio 2024</option>
                </select>
                <button id="btn-next-periodo" style="background: #ffffff; border: 1px solid var(--cta-border); padding: 8px 12px; border-radius: 6px; cursor: pointer; color: var(--cta-text-secondary); font-size: 12px; font-weight: 700; transition: all var(--cta-transition);" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='#ffffff'" title="Período siguiente">
                    &rsaquo;
                </button>
            </div>
        </div>

        <div>
            <label for="select-estado" style="display: block; font-size: 12px; font-weight: 600; color: var(--cta-text-secondary); margin-bottom: 6px;">Estado de Envío (SUNAT)</label>
            <select id="select-estado" style="width: 100%; padding: 8px 10px; border: 1px solid var(--cta-border); background: #ffffff; border-radius: 6px; font-size: 13px; color: var(--cta-text-primary); outline: none;">
                <option value="Pendiente">Pendiente de envío</option>
                <option value="Enviado">Enviado</option>
                <option value="Aceptado">Aceptado</option>
            </select>
        </div>

        <div>
            <button id="btn-sincronizar" style="width: 100%; background: #d97706; color: #ffffff; border: none; padding: 10px 16px; border-radius: 6px; font-size: 13px; font-weight: 600; cursor: pointer; transition: background var(--cta-transition);" onmouseover="this.style.background='#b45309'" onmouseout="this.style.background='#d97706'">
                Sincronizar SUNAT
            </button>
        </div>
    </div>

    <!-- 5. Resumen de Período (Métricas antes de los tabs) -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 28px;">
        
        <!-- Ventas Gravadas -->
        <div style="background: #ffffff; border: 1px solid var(--cta-border); border-left: 4px solid #d97706; padding: 16px; border-radius: 6px; box-shadow: var(--cta-shadow);">
            <span style="font-size: 11px; font-weight: 600; color: var(--cta-text-muted); text-transform: uppercase;">Ventas Gravadas (PEN)</span>
            <h3 id="res-ventas-grav" style="font-size: 18px; font-weight: 700; color: var(--cta-text-primary); margin: 4px 0 0 0;">S/ 0.00</h3>
        </div>

        <!-- IGV Ventas -->
        <div style="background: #ffffff; border: 1px solid var(--cta-border); border-left: 4px solid #d97706; padding: 16px; border-radius: 6px; box-shadow: var(--cta-shadow);">
            <span style="font-size: 11px; font-weight: 600; color: var(--cta-text-muted); text-transform: uppercase;">IGV Ventas (PEN)</span>
            <h3 id="res-igv-ventas" style="font-size: 18px; font-weight: 700; color: var(--cta-text-primary); margin: 4px 0 0 0;">S/ 0.00</h3>
        </div>

        <!-- Compras Gravadas -->
        <div style="background: #ffffff; border: 1px solid var(--cta-border); border-left: 4px solid #3b5bdb; padding: 16px; border-radius: 6px; box-shadow: var(--cta-shadow);">
            <span style="font-size: 11px; font-weight: 600; color: var(--cta-text-muted); text-transform: uppercase;">Compras Gravadas (PEN)</span>
            <h3 id="res-compras-grav" style="font-size: 18px; font-weight: 700; color: var(--cta-text-primary); margin: 4px 0 0 0;">S/ 0.00</h3>
        </div>

        <!-- IGV Compras -->
        <div style="background: #ffffff; border: 1px solid var(--cta-border); border-left: 4px solid #3b5bdb; padding: 16px; border-radius: 6px; box-shadow: var(--cta-shadow);">
            <span style="font-size: 11px; font-weight: 600; color: var(--cta-text-muted); text-transform: uppercase;">IGV Compras (PEN)</span>
            <h3 id="res-igv-compras" style="font-size: 18px; font-weight: 700; color: var(--cta-text-primary); margin: 4px 0 0 0;">S/ 0.00</h3>
        </div>

        <!-- Crédito Fiscal (Fila completa o doble ancho) -->
        <div style="grid-column: 1 / -1; background: #fffbf7; border: 1px solid #fcd34d; padding: 16px; border-radius: 6px; box-shadow: var(--cta-shadow); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px;">
            <div>
                <h4 style="margin: 0; font-size: 14px; font-weight: 700; color: #b45309;">Cálculo de Crédito Fiscal Estimado</h4>
                <p style="margin: 2px 0 0 0; font-size: 12px; color: var(--cta-text-secondary);">Calculado en base a Ventas IGV menos Compras IGV homologado a soles (T.C. USD = 3.75).</p>
            </div>
            <div>
                <h3 id="res-credito-fiscal" style="font-size: 22px; font-weight: 800; color: #d97706; margin: 0;">S/ 0.00</h3>
            </div>
        </div>

    </div>

    <!-- 5. RESUMEN TRIBUTARIO EXPANDIDO (Formulario 621) -->
    <div style="background: #ffffff; border: 1px solid var(--cta-border); border-radius: var(--cta-radius); padding: 16px; margin-bottom: 24px; box-shadow: var(--cta-shadow);">
        <div id="btn-toggle-dj" style="display: flex; justify-content: space-between; align-items: center; cursor: pointer; user-select: none;">
            <div style="display: flex; align-items: center; gap: 8px;">
                <div style="background: rgba(217, 119, 6, 0.08); color: #d97706; padding: 6px; border-radius: 6px; display: flex; align-items: center;">
                    <svg viewBox="0 0 24 24" style="width: 18px; height: 18px; fill: none; stroke: currentColor; stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round;">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="9" y1="9" x2="15" y2="9"></line>
                        <line x1="9" y1="13" x2="15" y2="13"></line>
                        <line x1="9" y1="17" x2="15" y2="17"></line>
                    </svg>
                </div>
                <h4 style="font-size: 13.5px; font-weight: 700; color: #b45309; margin: 0;">Formulario Virtual 621 - Liquidación Determinativa de IGV</h4>
            </div>
            <span id="toggle-dj-icon" style="font-size: 11px; color: var(--cta-text-secondary); font-weight: 600; border: 1px solid var(--cta-border); padding: 4px 8px; border-radius: 4px; background: #f8fafc;">▼ Expandir Formulario</span>
        </div>
        
        <div id="panel-dj" style="display: none; border-top: 1px solid var(--cta-border); margin-top: 16px; padding-top: 16px;">
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 24px; margin-bottom: 16px;">
                <!-- Columna Débito Fiscal -->
                <div>
                    <h5 style="font-size: 12px; font-weight: 700; color: #b45309; margin-bottom: 12px; border-bottom: 2px solid #fcd34d; padding-bottom: 4px; text-transform: uppercase; letter-spacing: 0.5px;">Débito Fiscal (Ventas)</h5>
                    <div style="display: flex; flex-direction: column; gap: 8px; font-size: 12.5px;">
                        <div style="display: flex; justify-content: space-between; border-bottom: 1px dashed var(--cta-border); padding-bottom: 4px; color: var(--cta-text-secondary);">
                            <span>Casilla 100 - Ventas Netas Gravadas</span>
                            <span id="dj-v-base" style="font-weight: 600; font-family: monospace; color: var(--cta-text-primary);">S/ 0.00</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; border-bottom: 1px dashed var(--cta-border); padding-bottom: 4px; color: var(--cta-text-secondary);">
                            <span>Casilla 105 - Ventas Exoneradas / Inafectas</span>
                            <span id="dj-v-nograv" style="font-weight: 600; font-family: monospace; color: var(--cta-text-primary);">S/ 0.00</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; font-weight: 700; border-top: 1px solid var(--cta-text-primary); padding-top: 6px; color: var(--cta-text-primary);">
                            <span>Total Débito Fiscal IGV (A)</span>
                            <span id="dj-v-igv" style="font-family: monospace;">S/ 0.00</span>
                        </div>
                    </div>
                </div>
                
                <!-- Columna Crédito Fiscal -->
                <div>
                    <h5 style="font-size: 12px; font-weight: 700; color: #3b5bdb; margin-bottom: 12px; border-bottom: 2px solid #bfdbfe; padding-bottom: 4px; text-transform: uppercase; letter-spacing: 0.5px;">Crédito Fiscal (Compras)</h5>
                    <div style="display: flex; flex-direction: column; gap: 8px; font-size: 12.5px;">
                        <div style="display: flex; justify-content: space-between; border-bottom: 1px dashed var(--cta-border); padding-bottom: 4px; color: var(--cta-text-secondary);">
                            <span>Casilla 107 - Compras Destinadas a Venta Gravada</span>
                            <span id="dj-c-base" style="font-weight: 600; font-family: monospace; color: var(--cta-text-primary);">S/ 0.00</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; border-bottom: 1px dashed var(--cta-border); padding-bottom: 4px; color: var(--cta-text-secondary);">
                            <span>Casilla 120 - Compras No Gravadas / Internas</span>
                            <span id="dj-c-nograv" style="font-weight: 600; font-family: monospace; color: var(--cta-text-primary);">S/ 0.00</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; font-weight: 700; border-top: 1px solid var(--cta-text-primary); padding-top: 6px; color: var(--cta-text-primary);">
                            <span>Total Crédito Fiscal IGV (B)</span>
                            <span id="dj-c-igv" style="font-family: monospace;">S/ 0.00</span>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Determinación del Impuesto Resultante -->
            <div style="background: #fffbeb; border: 1px solid #fcd34d; border-radius: 6px; padding: 12px 16px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px;">
                <div>
                    <h5 style="margin: 0; font-size: 13px; font-weight: 700; color: #b45309;">Casilla 184 - Impuesto Resultante o Saldo a Favor</h5>
                    <p style="margin: 2px 0 0 0; font-size: 11.5px; color: var(--cta-text-secondary);">Diferencia de obligaciones mensuales autoliquidadas: Débito (A) - Crédito (B)</p>
                </div>
                <div style="text-align: right;">
                    <span id="dj-resultado-label" style="font-size: 10px; font-weight: 700; text-transform: uppercase; color: var(--cta-text-secondary); display: block; margin-bottom: 2px;">Cargando...</span>
                    <span id="dj-resultado" style="font-size: 18px; font-weight: 800; font-family: monospace; color: #d97706;">S/ 0.00</span>
                </div>
            </div>
        </div>
    </div>

    <!-- 3. ACCIONES SIRE Y FILTROS AVANZADOS -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; flex-wrap: wrap; gap: 12px;">
        <div style="display: flex; gap: 8px; flex-wrap: wrap;">
            <button id="btn-filtros-avanzados" style="background: #ffffff; border: 1px solid var(--cta-border); color: var(--cta-text-secondary); padding: 9px 14px; border-radius: 6px; font-size: 12.5px; font-weight: 600; cursor: pointer; transition: all var(--cta-transition); display: flex; align-items: center; gap: 6px;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='#ffffff'">
                <svg viewBox="0 0 24 24" style="width: 15px; height: 15px; fill: none; stroke: currentColor; stroke-width: 2.5;">
                    <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
                </svg>
                Filtros Avanzados
            </button>
            <button id="btn-propuesta-sunat" style="background: #ffffff; border: 1px solid #fcd34d; color: #b45309; padding: 9px 14px; border-radius: 6px; font-size: 12.5px; font-weight: 600; cursor: pointer; transition: all var(--cta-transition); display: flex; align-items: center; gap: 6px;" onmouseover="this.style.background='#fffbf0'" onmouseout="this.style.background='#ffffff'">
                <svg viewBox="0 0 24 24" style="width: 15px; height: 15px; fill: none; stroke: currentColor; stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round;">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="12" y1="16" x2="12" y2="12"></line>
                    <line x1="12" y1="8" x2="12.01" y2="8"></line>
                </svg>
                Ver Propuesta SUNAT
            </button>
        </div>
        
        <div>
            <button id="btn-generar-txt" style="background: #3b5bdb; color: #ffffff; border: none; padding: 10px 16px; border-radius: 6px; font-size: 12.5px; font-weight: 600; cursor: pointer; transition: background var(--cta-transition); display: flex; align-items: center; gap: 6px;" onmouseover="this.style.background='#2b49c4'" onmouseout="this.style.background='#3b5bdb'">
                <svg viewBox="0 0 24 24" style="width: 15px; height: 15px; fill: none; stroke: currentColor; stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round;">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="7 10 12 15 17 10"></polyline>
                    <line x1="12" y1="15" x2="12" y2="3"></line>
                </svg>
                Generar TXT para SUNAT
            </button>
        </div>
    </div>

    <!-- Panel Desplegable Filtros Avanzados -->
    <div id="panel-filtros-avanzados" style="display: none; background: #f8fafc; border: 1px solid var(--cta-border); border-radius: var(--cta-radius); padding: 16px; margin-bottom: 20px;">
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; align-items: center;">
            <div style="display: flex; align-items: center; gap: 8px;">
                <input type="checkbox" id="chk-obs" style="width: 16px; height: 16px; accent-color: #3b5bdb; cursor: pointer;">
                <label for="chk-obs" style="font-size: 13px; font-weight: 600; color: var(--cta-text-primary); cursor: pointer; user-select: none;">Solo observaciones / errores</label>
            </div>
            <div>
                <label for="filter-tipo-op" style="display: block; font-size: 11px; font-weight: 600; color: var(--cta-text-secondary); margin-bottom: 4px;">Tipo de Operación</label>
                <select id="filter-tipo-op" style="width: 100%; padding: 6px 8px; border: 1px solid var(--cta-border); background: #ffffff; border-radius: 6px; font-size: 12.5px; color: var(--cta-text-primary); outline: none;">
                    <option value="Todos">Todas las operaciones</option>
                    <option value="Gravada">Gravada</option>
                    <option value="Exonerada">Exonerada</option>
                </select>
            </div>
            <div>
                <label style="display: block; font-size: 11px; font-weight: 600; color: var(--cta-text-secondary); margin-bottom: 4px;">Rango de Monto Total (PEN)</label>
                <div style="display: flex; align-items: center; gap: 6px;">
                    <input type="number" id="filter-monto-min" placeholder="Min" style="width: 100%; padding: 6px 8px; border: 1px solid var(--cta-border); border-radius: 6px; font-size: 12.5px; outline: none; background: #ffffff;">
                    <span style="font-size: 12px; color: var(--cta-text-muted);">-</span>
                    <input type="number" id="filter-monto-max" placeholder="Max" style="width: 100%; padding: 6px 8px; border: 1px solid var(--cta-border); border-radius: 6px; font-size: 12.5px; outline: none; background: #ffffff;">
                </div>
            </div>
        </div>
    </div>

    <!-- 2. Tabs Principales -->
    <div style="display: flex; gap: 8px; border-bottom: 1px solid var(--cta-border); padding-bottom: 2px; margin-bottom: 20px;">
        <button id="tab-rv" class="cta-tab active" style="font-size: 14px; font-weight: 600; padding: 10px 20px; border: none; background: none; border-bottom: 2px solid #3b5bdb; color: #3b5bdb; cursor: pointer; transition: all var(--cta-transition);">
            Registro de Ventas (RVIE)
        </button>
        <button id="tab-rc" class="cta-tab" style="font-size: 14px; font-weight: 500; padding: 10px 20px; border: none; background: none; border-bottom: 2px solid transparent; color: var(--cta-text-muted); cursor: pointer; transition: all var(--cta-transition);">
            Registro de Compras (RCE)
        </button>
    </div>

    <!-- 3. Contenedor Tabla Ventas (Tab RV) -->
    <div id="panel-rv" class="cta-tab-panel" style="display: block;">
        
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
            <span style="font-size: 13px; color: var(--cta-text-secondary); font-weight: 500;">Comprobantes de Ventas emitidos (SUNAT formato de descarga RVIE)</span>
            <span style="font-size: 12px; color: var(--cta-text-muted); font-style: italic;">* Arrastra horizontalmente la tabla para ver todos los campos.</span>
        </div>

        <div style="border: 1px solid var(--cta-border); border-radius: var(--cta-radius); overflow: hidden; background: #ffffff; box-shadow: var(--cta-shadow);">
            <!-- Scroll horizontal obligatorio y alto limitado con cabecera fija -->
            <div style="overflow-x: auto; width: 100%; max-height: 400px; overflow-y: auto; position: relative;">
                <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.875rem; min-width: 1300px;">
                    
                    <!-- Header Fijo -->
                    <thead style="position: sticky; top: 0; z-index: 10;">
                        <tr style="background-color: #fffbf0; border-bottom: 1px solid #fcd34d; color: #b45309; font-weight: 600;">
                            <th style="padding: 12px 14px; font-weight: 600; width: 60px; text-align: center;">Estado</th>
                            <th style="padding: 12px 14px; font-weight: 600;">Período</th>
                            <th style="padding: 12px 14px; font-weight: 600; text-align: center; width: 70px;">Tipo Doc</th>
                            <th style="padding: 12px 14px; font-weight: 600; width: 80px;">Serie</th>
                            <th style="padding: 12px 14px; font-weight: 600; width: 100px;">Número</th>
                            <th style="padding: 12px 14px; font-weight: 600; width: 95px;">Fecha</th>
                            <th style="padding: 12px 14px; font-weight: 600; width: 110px;">RUC</th>
                            <th style="padding: 12px 14px; font-weight: 600;">Razón Social</th>
                            <th style="padding: 12px 14px; font-weight: 600; text-align: center; width: 70px;">Moneda</th>
