<div id="cta-drawer-overlay" style="position: fixed; inset: 0; background: rgba(0,0,0,0.4); backdrop-filter: blur(2px); z-index: 999; display: none; opacity: 0; transition: opacity 0.3s ease;"></div>

<!-- CSS local overrides and animations -->
<style>
    @@keyframes ctaFadeIn {
        from { opacity: 0; transform: translateY(6px); }
        to { opacity: 1; transform: translateY(0); }
    }
    @@keyframes ctaSlideDown {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<!-- 5. Scripts de Recálculo, Homologación y Tabulación en Cliente -->
<script>
    document.addEventListener("DOMContentLoaded", function() {
        // Datos de Ventas RV completos
        var dbVentas = [
            @foreach (var v in ventasRV)
            {
                <text>{ periodo: "@v.Periodo", tipoDoc: "@v.TipoDoc", serie: "@v.Serie", correlativo: "@v.Correlativo", fecha: "@v.Fecha", ruc: "@v.Ruc", razonSocial: "@v.RazonSocial", moneda: "@v.Moneda", baseGrav: @v.BaseGrav, igv: @v.Igv, baseNoGrav: @v.BaseNoGrav, total: @v.Total, tipoOp: "@v.TipoOp" },</text>
            }
        ];

        // Datos de Compras RC completos
        var dbCompras = [
            @foreach (var c in comprasRC)
            {
                <text>{ periodo: "@c.Periodo", tipoDoc: "@c.TipoDoc", serie: "@c.Serie", correlativo: "@c.Correlativo", fecha: "@c.Fecha", fechaVenc: "@c.FechaVenc", ruc: "@c.Ruc", razonSocial: "@c.RazonSocial", moneda: "@c.Moneda", tc: @c.TC, baseGrav: @c.BaseGrav, igv: @c.Igv, noGravado: @c.NoGravado, total: @c.Total, anotado: "@c.Anotado" },</text>
            }
        ];

        // Referencias DOM Tabs
        var tabRV = document.getElementById("tab-rv");
        var tabRC = document.getElementById("tab-rc");
        var panelRV = document.getElementById("panel-rv");
        var panelRC = document.getElementById("panel-rc");

        // Referencias DOM Selector Periodo y Navegación
        var selectPeriodo = document.getElementById("select-periodo");
        var btnPrevPeriodo = document.getElementById("btn-prev-periodo");
        var btnNextPeriodo = document.getElementById("btn-next-periodo");

        // Referencias DOM Métricas
        var resVentasGrav = document.getElementById("res-ventas-grav");
        var resIgvVentas = document.getElementById("res-igv-ventas");
        var resComprasGrav = document.getElementById("res-compras-grav");
        var resIgvCompras = document.getElementById("res-igv-compras");
        var resCreditoFiscal = document.getElementById("res-credito-fiscal");

        // Referencias DOM Totales Tabla Ventas
        var totRvBase = document.getElementById("tot-rv-base");
        var totRvIgv = document.getElementById("tot-rv-igv");
        var totRvNoGrav = document.getElementById("tot-rv-nograv");
        var totRvTotal = document.getElementById("tot-rv-total");

        // Referencias DOM Totales Tabla Compras
        var totRcBase = document.getElementById("tot-rc-base");
        var totRcIgv = document.getElementById("tot-rc-igv");
        var totRcNoGrav = document.getElementById("tot-rc-nograv");
        var totRcTotal = document.getElementById("tot-rc-total");

        // Utilidades numéricas
        function formatMoney(amount) {
            return "S/ " + amount.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }
        function formatNumberOnly(amount) {
            return amount.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }
        function stringJoinReverse(dateStr) {
            if (!dateStr) return "-";
            var parts = dateStr.split("-");
            if (parts.length === 3) {
                return parts[2] + "/" + parts[1] + "/" + parts[0];
            }
            return dateStr;
        }

        // --- 1. MOTOR DE VALIDACIÓN POR FILA ---
        function validateRow(item, type) {
            // Check Critical Error (IGV !== Base * 18% con tolerancia de 0.05)
            if (item.baseGrav > 0 && Math.abs(item.baseGrav * 0.18 - item.igv) > 0.05) {
                var expectedIgv = (item.baseGrav * 0.18).toFixed(2);
                return {
                    status: "error",
                    message: "Error crítico: El IGV reportado (S/ " + item.igv.toFixed(2) + ") no coincide con el 18% calculado de la base (S/ " + expectedIgv + ")."
                };
            }
            
            // Check Warning (RUC length !== 11 or starts with digits other than 10 or 20)
            if (item.ruc) {
                var cleanRuc = item.ruc.trim();
                if (cleanRuc.length !== 11 || (!cleanRuc.startsWith("10") && !cleanRuc.startsWith("20"))) {
                    return {
                        status: "warning",
                        message: "Observación: Formato de RUC inválido o inusual (debe tener 11 dígitos y comenzar con 10 o 20)."
                    };
                }
            }
            
            return {
                status: "valid",
                message: "Registro válido y consistente."
            };
        }

        // --- 2. GESTIÓN DE TABS PRINCIPALES RV / RC ---
        function switchTab(activeTabId) {
            if (activeTabId === "rv") {
                tabRV.classList.add("active");
                tabRV.style.borderBottom = "2px solid #3b5bdb";
                tabRV.style.color = "#3b5bdb";
                
                tabRC.classList.remove("active");
                tabRC.style.borderBottom = "2px solid transparent";
                tabRC.style.color = "var(--cta-text-muted)";
                
                panelRV.style.display = "block";
                panelRC.style.display = "none";
            } else {
                tabRC.classList.add("active");
                tabRC.style.borderBottom = "2px solid #3b5bdb";
                tabRC.style.color = "#3b5bdb";
                
                tabRV.classList.remove("active");
                tabRV.style.borderBottom = "2px solid transparent";
                tabRV.style.color = "var(--cta-text-muted)";
                
                panelRC.style.display = "block";
                panelRV.style.display = "none";
            }
            renderTable();
        }

        tabRV.addEventListener("click", function() { switchTab("rv"); });
        tabRC.addEventListener("click", function() { switchTab("rc"); });

        // --- GESTIÓN DINÁMICA DE ESTADO DE ENVÍO ---
        var selectEstado = document.getElementById("select-estado");
        var badgeEstado = document.getElementById("badge-estado");

        if (selectEstado && badgeEstado) {
            selectEstado.addEventListener("change", function() {
                var val = selectEstado.value;
                if (val === "Pendiente") {
                    badgeEstado.textContent = "Pendiente de envío";
                    badgeEstado.style.background = "rgba(217, 119, 6, 0.12)";
                    badgeEstado.style.color = "#d97706";
                    badgeEstado.style.border = "1px solid rgba(217, 119, 6, 0.2)";
                } else if (val === "Enviado") {
                    badgeEstado.textContent = "Enviado";
                    badgeEstado.style.background = "rgba(59, 93, 219, 0.12)";
                    badgeEstado.style.color = "#3b5bdb";
                    badgeEstado.style.border = "1px solid rgba(59, 93, 219, 0.2)";
                } else if (val === "Aceptado") {
                    badgeEstado.textContent = "Aceptado";
                    badgeEstado.style.background = "rgba(16, 185, 129, 0.12)";
                    badgeEstado.style.color = "#10b981";
                    badgeEstado.style.border = "1px solid rgba(16, 185, 129, 0.2)";
                }
            });
        }

        // --- 5. RESUMEN TRIBUTARIO FORMULARIO 621 ACCORDION TOGGLE ---
        var btnToggleDj = document.getElementById("btn-toggle-dj");
        var panelDj = document.getElementById("panel-dj");
        var toggleDjIcon = document.getElementById("toggle-dj-icon");

        if (btnToggleDj && panelDj && toggleDjIcon) {
            btnToggleDj.addEventListener("click", function() {
                if (panelDj.style.display === "none" || panelDj.style.display === "") {
                    panelDj.style.display = "block";
                    toggleDjIcon.textContent = "▲ Colapsar Formulario";
                    panelDj.style.animation = "ctaSlideDown 200ms ease-out";
                } else {
                    panelDj.style.display = "none";
                    toggleDjIcon.textContent = "▼ Expandir Formulario";
                }
            });
        }

        // --- 3. ACCIONES Y FILTROS AVANZADOS TOGGLE ---
        var btnFiltros = document.getElementById("btn-filtros-avanzados");
        var panelFiltros = document.getElementById("panel-filtros-avanzados");

        if (btnFiltros && panelFiltros) {
            btnFiltros.addEventListener("click", function() {
                if (panelFiltros.style.display === "none" || panelFiltros.style.display === "") {
                    panelFiltros.style.display = "block";
                    panelFiltros.style.animation = "ctaSlideDown 200ms ease-out";
                    btnFiltros.style.background = "var(--cta-primary-soft)";
                    btnFiltros.style.color = "var(--cta-primary)";
                    btnFiltros.style.borderColor = "var(--cta-primary)";
                } else {
                    panelFiltros.style.display = "none";
                    btnFiltros.style.background = "#ffffff";
                    btnFiltros.style.color = "var(--cta-text-secondary)";
                    btnFiltros.style.borderColor = "var(--cta-border)";
                }
            });
        }

        // Suscribir eventos de filtros avanzados
        document.getElementById("chk-obs").addEventListener("change", renderTable);
        document.getElementById("filter-tipo-op").addEventListener("change", renderTable);
        document.getElementById("filter-monto-min").addEventListener("input", renderTable);
        document.getElementById("filter-monto-max").addEventListener("input", renderTable);

        // --- 6. NAVEGACIÓN POR PERÍODO CON FLECHAS ---
        if (btnPrevPeriodo) {
            btnPrevPeriodo.addEventListener("click", function() {
                var currentIndex = selectPeriodo.selectedIndex;
                if (currentIndex > 0) {
                    selectPeriodo.selectedIndex = currentIndex - 1;
                    selectPeriodo.dispatchEvent(new Event("change"));
                }
            });
        }

        if (btnNextPeriodo) {
            btnNextPeriodo.addEventListener("click", function() {
                var currentIndex = selectPeriodo.selectedIndex;
                if (currentIndex < selectPeriodo.options.length - 1) {
                    selectPeriodo.selectedIndex = currentIndex + 1;
                    selectPeriodo.dispatchEvent(new Event("change"));
                }
            });
        }

        selectPeriodo.addEventListener("change", function() {
            var currentIndex = selectPeriodo.selectedIndex;
            if (btnPrevPeriodo) btnPrevPeriodo.disabled = (currentIndex === 0);
            if (btnNextPeriodo) btnNextPeriodo.disabled = (currentIndex === selectPeriodo.options.length - 1);
            
            // Actualizar estadísticas de periodo y redibujar tablas
            updatePeriodStats();
            renderTable();
        });

        // --- DRAWER COMPARATIVO PROPUESTA SUNAT ---
        var btnPropuesta = document.getElementById("btn-propuesta-sunat");
        var btnCloseDrawer = document.getElementById("btn-close-drawer");
        var btnCloseDrawerFooter = document.getElementById("btn-close-drawer-footer");
        var drawer = document.getElementById("cta-drawer");
        var drawerOverlay = document.getElementById("cta-drawer-overlay");

        function openDrawer() {
            renderSunatProposal();
            drawer.style.right = "0";
            drawerOverlay.style.display = "block";
            setTimeout(function() {
                drawerOverlay.style.opacity = "1";
            }, 10);
        }

        function closeDrawer() {
            drawer.style.right = "-500px";
            drawerOverlay.style.opacity = "0";
            setTimeout(function() {
                drawerOverlay.style.display = "none";
            }, 300);
        }

        if (btnPropuesta) btnPropuesta.addEventListener("click", openDrawer);
        if (btnCloseDrawer) btnCloseDrawer.addEventListener("click", closeDrawer);
        if (btnCloseDrawerFooter) btnCloseDrawerFooter.addEventListener("click", closeDrawer);
        if (drawerOverlay) drawerOverlay.addEventListener("click", closeDrawer);

        // Aceptar propuesta SUNAT y homologar datos locales
        var btnReemplazar = document.getElementById("btn-reemplazar-propuesta");
        if (btnReemplazar) {
            btnReemplazar.addEventListener("click", function() {
                var activeTab = tabRV.classList.contains("active") ? "rv" : "rc";
                if (activeTab === "rv") {
                    // Corregir fila 5 (index 4) de ventas
                    dbVentas[4].igv = dbVentas[4].baseGrav * 0.18;
                    dbVentas[4].total = dbVentas[4].baseGrav + dbVentas[4].igv;
                } else {
                    // Corregir fila 8 (index 7) de compras
                    dbCompras[7].igv = dbCompras[7].baseGrav * 0.18;
                    dbCompras[7].total = dbCompras[7].baseGrav + dbCompras[7].igv;
                }
                
                alert("Propuesta SUNAT homologada exitosamente. Se han corregido las discrepancias de IGV en sus registros locales.");
                closeDrawer();
                updatePeriodStats();
                renderTable();
            });
        }

        function renderSunatProposal() {
            var activeTab = tabRV.classList.contains("active") ? "rv" : "rc";
            var periodValue = selectPeriodo.value;
            var multiplier = 1.0;
            if (periodValue === "2024-04") multiplier = 0.88;
            if (periodValue === "2024-06") multiplier = 1.12;

            var rawData = (activeTab === "rv") ? dbVentas : dbCompras;
            var tbody = document.getElementById("drawer-comparison-body");
            tbody.innerHTML = "";

            rawData.forEach(function(item, index) {
                var copy = Object.assign({}, item);
                copy.baseGrav = item.baseGrav * multiplier;
                copy.igv = item.igv * multiplier;
                copy.total = item.total * multiplier;

                var compNumber = copy.serie + "-" + copy.correlativo;
                
                // Simulación de diferencias
                var sunatTotal = copy.total;
                if (activeTab === "rv" && index === 4) {
                    sunatTotal = (copy.baseGrav + copy.baseGrav * 0.18); // F001-0008545 corregido
                }
                if (activeTab === "rc" && index === 7) {
                    sunatTotal = (copy.baseGrav + copy.baseGrav * 0.18); // F003-0001254 corregido
                }

                var tuTotal = copy.total;
                var dif = sunatTotal - tuTotal;
                var hasDiff = Math.abs(dif) > 0.01;
                
                var trStyle = hasDiff ? 'background: #fffbeb; font-weight: 600;' : '';
                var tdClass = hasDiff ? 'style="padding: 10px 12px; border-bottom: 1px solid var(--cta-border); color: #b45309;"' : 'style="padding: 10px 12px; border-bottom: 1px solid var(--cta-border); color: var(--cta-text-primary);"';
                var tdRightClass = hasDiff ? 'style="padding: 10px 12px; border-bottom: 1px solid var(--cta-border); text-align: right; color: #b45309;"' : 'style="padding: 10px 12px; border-bottom: 1px solid var(--cta-border); text-align: right; color: var(--cta-text-primary);"';

                var rowHtml = `
                    <tr style="${trStyle}">
                        <td ${tdClass}>${compNumber}</td>
                        <td ${tdRightClass}>S/ ${formatNumberOnly(sunatTotal)}</td>
                        <td ${tdRightClass}>S/ ${formatNumberOnly(tuTotal)}</td>
                        <td ${tdRightClass} style="color: ${dif !== 0 ? '#ef4444' : '#10b981'}; font-weight: 700;">S/ ${formatNumberOnly(dif)}</td>
                    </tr>
                `;
                tbody.insertAdjacentHTML("beforeend", rowHtml);
            });
        }

        // --- 4. GENERACIÓN DE ARCHIVO TXT ESTRUCTURADO SUNAT ---
        var btnGenerarTxt = document.getElementById("btn-generar-txt");
        if (btnGenerarTxt) {
            btnGenerarTxt.addEventListener("click", function() {
                var activeTab = tabRV.classList.contains("active") ? "rv" : "rc";
                var periodValue = selectPeriodo.value;
                var cleanPeriod = periodValue.replace("-", ""); // "202405"
                var activeRuc = document.getElementById("select-ruc").value;
                
                var rawData = (activeTab === "rv") ? dbVentas : dbCompras;
                var multiplier = 1.0;
                if (periodValue === "2024-04") multiplier = 0.88;
                if (periodValue === "2024-06") multiplier = 1.12;

                var txtLines = [];
                rawData.forEach(function(item) {
                    var copy = Object.assign({}, item);
                    copy.baseGrav = item.baseGrav * multiplier;
                    copy.igv = item.igv * multiplier;
                    copy.total = item.total * multiplier;
                    if (copy.baseNoGrav !== undefined) copy.baseNoGrav = item.baseNoGrav * multiplier;
                    if (copy.noGravado !== undefined) copy.noGravado = item.noGravado * multiplier;
                    
                    var line = "";
                    if (activeTab === "rv") {
                        line = [
                            cleanPeriod,
                            copy.ruc,
                            copy.razonSocial,
                            copy.tipoDoc,
                            copy.serie,
                            copy.correlativo,
                            copy.fecha,
                            copy.moneda,
                            copy.baseGrav.toFixed(2),
                            copy.igv.toFixed(2),
                            copy.baseNoGrav.toFixed(2),
                            copy.total.toFixed(2),
                            copy.tipoOp
                        ].join("|");
                    } else {
                        line = [
                            cleanPeriod,
                            copy.ruc,
                            copy.razonSocial,
                            copy.tipoDoc,
                            copy.serie,
                            copy.correlativo,
                            copy.fecha,
                            copy.fechaVenc,
                            copy.moneda,
                            copy.tc.toFixed(2),
                            copy.baseGrav.toFixed(2),
                            copy.igv.toFixed(2),
                            copy.noGravado.toFixed(2),
                            copy.total.toFixed(2),
                            copy.anotado
                        ].join("|");
                    }
                    txtLines.push(line);
                });

                var txtContent = txtLines.join("\r\n");
                var tipo = (activeTab === "rv") ? "140100" : "140200";
                var fileName = "LE" + activeRuc + cleanPeriod + "00" + tipo + "00.txt";

                var blob = new Blob([txtContent], { type: "text/plain;charset=utf-8" });
                var url = URL.createObjectURL(blob);
                var a = document.createElement("a");
                a.href = url;
                a.download = fileName;
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                URL.revokeObjectURL(url);

                alert("Se ha generado y descargado con éxito el archivo estructurado para SIRE SUNAT:\n\n" + fileName + "\n\nRegistros procesados: " + txtLines.length);
            });
        }

        // --- MOTOR CENTRAL DE RENDERIZACIÓN DE TABLAS ---
        function renderTable() {
            var activeTab = tabRV.classList.contains("active") ? "rv" : "rc";
            var periodValue = selectPeriodo.value;
            var cleanPeriod = periodValue.replace("-", "");
            
            var rawData = (activeTab === "rv") ? dbVentas : dbCompras;
            var multiplier = 1.0;
            if (periodValue === "2024-04") multiplier = 0.88;
            if (periodValue === "2024-06") multiplier = 1.12;

            // Procesar y mapear datos
            var filteredData = rawData.map(function(item) {
                var copy = Object.assign({}, item);
                copy.periodo = cleanPeriod;
                copy.baseGrav = item.baseGrav * multiplier;
                copy.igv = item.igv * multiplier;
                copy.total = item.total * multiplier;
                if (copy.baseNoGrav !== undefined) copy.baseNoGrav = item.baseNoGrav * multiplier;
                if (copy.noGravado !== undefined) copy.noGravado = item.noGravado * multiplier;
                
                // Mover fechas según periodo
                if (periodValue === "2024-04") {
                    copy.fecha = copy.fecha.replace("-05-", "-04-");
                    if (copy.fechaVenc) copy.fechaVenc = copy.fechaVenc.replace("-06-", "-05-").replace("-05-", "-04-");
                }
                if (periodValue === "2024-06") {
                    copy.fecha = copy.fecha.replace("-05-", "-06-");
                    if (copy.fechaVenc) copy.fechaVenc = copy.fechaVenc.replace("-06-", "-07-").replace("-05-", "-06-");
                }
                return copy;
            });

            // Aplicar filtros avanzados
            var chkObs = document.getElementById("chk-obs").checked;
            var filterTipoOp = document.getElementById("filter-tipo-op").value;
            var minMonto = parseFloat(document.getElementById("filter-monto-min").value) || 0;
            var maxMonto = parseFloat(document.getElementById("filter-monto-max").value) || Infinity;

            filteredData = filteredData.filter(function(item) {
                // Filtro solo observaciones / errores
                var val = validateRow(item, activeTab);
                if (chkObs && val.status === "valid") return false;

                // Filtro tipo operación (Ventas)
                if (activeTab === "rv" && filterTipoOp !== "Todos" && item.tipoOp !== filterTipoOp) return false;

                // Filtro por rango de montos
                if (item.total < minMonto || item.total > maxMonto) return false;

                return true;
            });

            // Renderizar en el tbody correspondiente
            var tbody = (activeTab === "rv") ? document.querySelector("#panel-rv tbody") : document.querySelector("#panel-rc tbody");
            tbody.innerHTML = "";

            if (filteredData.length === 0) {
                var cols = (activeTab === "rv") ? 16 : 14;
                tbody.innerHTML = `<tr><td colspan="${cols}" style="text-align: center; padding: 32px; color: var(--cta-text-muted); font-style: italic;">No se encontraron registros que coincidan con los filtros seleccionados.</td></tr>`;
            } else {
                filteredData.forEach(function(item) {
                    var val = validateRow(item, activeTab);
                    var iconHtml = "";
                    if (val.status === "valid") {
                        iconHtml = `<span style="color:#10b981; font-weight:700; font-size:15px; cursor:help;" title="${val.message}">✓</span>`;
                    } else if (val.status === "warning") {
                        iconHtml = `<span style="color:#d97706; font-weight:700; font-size:15px; cursor:help;" title="${val.message}">⚠</span>`;
                    } else if (val.status === "error") {
                        iconHtml = `<span style="color:#ef4444; font-weight:700; font-size:15px; cursor:help;" title="${val.message}">✗</span>`;
                    }

                    var rowHtml = "";
                    if (activeTab === "rv") {
                        var dateStr = stringJoinReverse(item.fecha);
                        rowHtml = `
                            <tr class="sire-row" style="border-bottom: 1px solid var(--cta-border); transition: background var(--cta-transition);" onmouseover="this.style.background='#fffbf7'" onmouseout="this.style.background='none'">
                                <td style="padding: 12px 14px; text-align: center; font-weight: 700;">${iconHtml}</td>
                                <td style="padding: 12px 14px; font-family: monospace;">${item.periodo}</td>
                                <td style="padding: 12px 14px; text-align: center; font-family: monospace;">${item.tipoDoc}</td>
                                <td style="padding: 12px 14px; font-family: monospace;">${item.serie}</td>
                                <td style="padding: 12px 14px; font-family: monospace;">${item.correlativo}</td>
                                <td style="padding: 12px 14px; white-space: nowrap;">${dateStr}</td>
                                <td style="padding: 12px 14px; font-family: monospace;">${item.ruc}</td>
                                <td style="padding: 12px 14px; max-width: 220px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="${item.razonSocial}">${item.razonSocial}</td>
                                <td style="padding: 12px 14px; text-align: center; font-weight: 600; font-size: 11.5px;">${item.moneda}</td>
                                <td style="padding: 12px 14px; text-align: right;">-</td>
                                <td style="padding: 12px 14px; text-align: right;">${item.baseGrav > 0 ? formatNumberOnly(item.baseGrav) : "0.00"}</td>
                                <td style="padding: 12px 14px; text-align: right;">${item.igv > 0 ? formatNumberOnly(item.igv) : "0.00"}</td>
                                <td style="padding: 12px 14px; text-align: right;">${item.baseNoGrav > 0 ? formatNumberOnly(item.baseNoGrav) : "0.00"}</td>
                                <td style="padding: 12px 14px; text-align: right;">-</td>
                                <td style="padding: 12px 14px; text-align: right;">-</td>
                                <td style="padding: 12px 14px; text-align: right; font-weight: 600; color: #d97706;">${formatNumberOnly(item.total)}</td>
                            </tr>
                        `;
                    } else {
                        var dateStr = stringJoinReverse(item.fecha);
                        var dateVencStr = stringJoinReverse(item.fechaVenc);
                        rowHtml = `
                            <tr class="sire-row" style="border-bottom: 1px solid var(--cta-border); transition: background var(--cta-transition);" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='none'">
                                <td style="padding: 12px 14px; text-align: center; font-weight: 700;">${iconHtml}</td>
                                <td style="padding: 12px 14px; font-family: monospace;">${item.ruc}</td>
                                <td style="padding: 12px 14px; max-width: 220px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="${item.razonSocial}">${item.razonSocial}</td>
                                <td style="padding: 12px 14px; text-align: center; font-family: monospace;">${item.tipoDoc}</td>
                                <td style="padding: 12px 14px; font-family: monospace;">${item.serie}-${item.correlativo}</td>
                                <td style="padding: 12px 14px; white-space: nowrap;">${dateStr}</td>
                                <td style="padding: 12px 14px; white-space: nowrap;">${dateVencStr}</td>
                                <td style="padding: 12px 14px; text-align: center; font-weight: 600; font-size: 11.5px;">${item.moneda}</td>
                                <td style="padding: 12px 14px; text-align: right; font-family: monospace;">${formatNumberOnly(item.tc)}</td>
                                <td style="padding: 12px 14px; text-align: right;">${item.baseGrav > 0 ? formatNumberOnly(item.baseGrav) : "0.00"}</td>
                                <td style="padding: 12px 14px; text-align: right;">${item.igv > 0 ? formatNumberOnly(item.igv) : "0.00"}</td>
                                <td style="padding: 12px 14px; text-align: right;">${item.noGravado > 0 ? formatNumberOnly(item.noGravado) : "0.00"}</td>
                                <td style="padding: 12px 14px; text-align: right; font-weight: 600; color: #3b5bdb;">${formatNumberOnly(item.total)}</td>
                                <td style="padding: 12px 14px; text-align: center;">
                                    ${item.anotado === "Sí" ? '<span style="color: #10b981; font-weight: 700; font-size: 13.5px;">✔</span>' : '<span style="color: #ef4444; font-weight: 700; font-size: 13.5px;">✘</span>'}
                                </td>
                            </tr>
                        `;
                    }
                    tbody.insertAdjacentHTML("beforeend", rowHtml);
                });
            }
            
            // Recalcular métricas de pie de tabla
            recalculateMetrics(filteredData, activeTab);
        }

        // --- MOTOR CENTRAL DE RECALCULO DE METRICAS DEL PERIODO (GLOBAL) ---
        function updatePeriodStats() {
            var periodValue = selectPeriodo.value;
            var cleanPeriod = periodValue.replace("-", "");
            var multiplier = 1.0;
            if (periodValue === "2024-04") multiplier = 0.88;
            if (periodValue === "2024-06") multiplier = 1.12;

            var sumVentasBase = 0;
            var sumVentasIgv = 0;
            var sumVentasNoGrav = 0;
            var sumVentasTotal = 0;

            var sumComprasBase = 0;
            var sumComprasIgv = 0;
            var sumComprasNoGrav = 0;
            var sumComprasTotal = 0;

            var countValid = 0;
            var countWarning = 0;
            var countError = 0;

            // Procesar Ventas
            dbVentas.forEach(function(item) {
                var copy = Object.assign({}, item);
                copy.baseGrav = item.baseGrav * multiplier;
                copy.igv = item.igv * multiplier;
                copy.total = item.total * multiplier;
                copy.baseNoGrav = item.baseNoGrav * multiplier;

                var tc = (copy.moneda === "USD") ? 3.75 : 1.00;
                sumVentasBase += (copy.baseGrav * tc);
                sumVentasIgv += (copy.igv * tc);
                sumVentasNoGrav += (copy.baseNoGrav * tc);
                sumVentasTotal += (copy.total * tc);

                var val = validateRow(copy, "rv");
                if (val.status === "valid") countValid++;
                else if (val.status === "warning") countWarning++;
                else if (val.status === "error") countError++;
            });

            // Procesar Compras
            dbCompras.forEach(function(item) {
                var copy = Object.assign({}, item);
                copy.baseGrav = item.baseGrav * multiplier;
                copy.igv = item.igv * multiplier;
                copy.total = item.total * multiplier;
                copy.noGravado = item.noGravado * multiplier;

                var tc = copy.tc;
                sumComprasBase += (copy.baseGrav * tc);
                sumComprasIgv += (copy.igv * tc);
                sumComprasNoGrav += (copy.noGravado * tc);
                sumComprasTotal += (copy.total * tc);

                var val = validateRow(copy, "rc");
                if (val.status === "valid") countValid++;
                else if (val.status === "warning") countWarning++;
                else if (val.status === "error") countError++;
            });

            // Inyectar contadores en el header diagnostico
            document.getElementById("count-valid").innerHTML = `<span style="display:inline-block; width:6px; height:6px; border-radius:50%; background:#10b981;"></span> ${countValid} Válidos`;
            document.getElementById("count-warning").innerHTML = `<span style="display:inline-block; width:6px; height:6px; border-radius:50%; background:#d97706;"></span> ${countWarning} Con Obs.`;
            document.getElementById("count-error").innerHTML = `<span style="display:inline-block; width:6px; height:6px; border-radius:50%; background:#ef4444;"></span> ${countError} Con Error`;

            // Inyectar en Tarjetas Resumen
            resVentasGrav.textContent = formatMoney(sumVentasBase);
            resIgvVentas.textContent = formatMoney(sumVentasIgv);
            resComprasGrav.textContent = formatMoney(sumComprasBase);
            resIgvCompras.textContent = formatMoney(sumComprasIgv);

            // Calcular Crédito Fiscal (IGV Ventas - IGV Compras en PEN)
            var creditoFiscal = sumVentasIgv - sumComprasIgv;
            var labelCF = document.getElementById("res-credito-fiscal");
            
            if (creditoFiscal >= 0) {
                labelCF.style.color = "#d97706";
                labelCF.innerHTML = formatMoney(creditoFiscal) + ' <span style="font-size: 12px; font-weight: 500; color: var(--cta-text-secondary); display: block; margin-top: 4px;">Debito / Impuesto por pagar</span>';
            } else {
                labelCF.style.color = "#10b981";
                labelCF.innerHTML = formatMoney(Math.abs(creditoFiscal)) + ' <span style="font-size: 12px; font-weight: 500; color: var(--cta-text-secondary); display: block; margin-top: 4px;">Saldo / Crédito Fiscal a favor</span>';
            }

            // Inyectar valores en el Formulario Virtual DJ 621
            document.getElementById("dj-v-base").textContent = formatMoney(sumVentasBase);
            document.getElementById("dj-v-nograv").textContent = formatMoney(sumVentasNoGrav);
            document.getElementById("dj-v-igv").textContent = formatMoney(sumVentasIgv);

            document.getElementById("dj-c-base").textContent = formatMoney(sumComprasBase);
            document.getElementById("dj-c-nograv").textContent = formatMoney(sumComprasNoGrav);
            document.getElementById("dj-c-igv").textContent = formatMoney(sumComprasIgv);

            var djResultado = document.getElementById("dj-resultado");
            var djResultadoLabel = document.getElementById("dj-resultado-label");
            if (creditoFiscal >= 0) {
                djResultado.textContent = formatMoney(creditoFiscal);
                djResultado.style.color = "#d97706";
                djResultadoLabel.textContent = "Casilla 184 - Impuesto a Pagar (Débito resultante)";
                djResultadoLabel.style.color = "#d97706";
            } else {
                djResultado.textContent = formatMoney(Math.abs(creditoFiscal));
                djResultado.style.color = "#10b981";
                djResultadoLabel.textContent = "Casilla 184 - Saldo a Favor del Contribuyente (Crédito resultante)";
                djResultadoLabel.style.color = "#10b981";
            }
        }

        // --- MOTOR DE RECALCULO DE METRICAS DEL PIE DE TABLA ---
        function recalculateMetrics(filteredData, activeTab) {
            var totTableBase = 0;
            var totTableIgv = 0;
            var totTableNoGrav = 0;
            var totTableTotal = 0;

            filteredData.forEach(function(item) {
                totTableBase += item.baseGrav;
                totTableIgv += item.igv;
                if (activeTab === "rv") {
                    totTableNoGrav += item.baseNoGrav;
                } else {
                    totTableNoGrav += item.noGravado;
                }
                totTableTotal += item.total;
            });

            if (activeTab === "rv") {
                totRvBase.textContent = formatNumberOnly(totTableBase);
                totRvIgv.textContent = formatNumberOnly(totTableIgv);
                totRvNoGrav.textContent = formatNumberOnly(totTableNoGrav);
                totRvTotal.textContent = formatNumberOnly(totTableTotal);
            } else {
                totRcBase.textContent = formatNumberOnly(totTableBase);
                totRcIgv.textContent = formatNumberOnly(totTableIgv);
                totRcNoGrav.textContent = formatNumberOnly(totTableNoGrav);
                totRcTotal.textContent = formatNumberOnly(totTableTotal);
            }
        }

        // Carga inicial y configuración de estados
        selectPeriodo.dispatchEvent(new Event("change"));
    });
</script>

