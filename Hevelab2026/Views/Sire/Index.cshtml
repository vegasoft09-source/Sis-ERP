            <div style="overflow-x: auto; width: 100%; max-height: 400px; overflow-y: auto; position: relative;">
                <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.875rem; min-width: 1300px;">
                    
                    <thead style="position: sticky; top: 0; z-index: 10;">
                        <tr style="background-color: #f0f4ff; border-bottom: 1px solid var(--cta-border); color: #3b5bdb; font-weight: 600;">
