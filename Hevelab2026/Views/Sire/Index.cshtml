            Aceptar Propuesta
        </button>
        <button id="btn-close-drawer-footer" style="background: #ffffff; border: 1px solid var(--cta-border); color: var(--cta-text-secondary); padding: 10px 16px; border-radius: 6px; font-size: 12.5px; font-weight: 600; cursor: pointer;" onmouseover="this.style.background='#f1f5f9'" onmouseout="this.style.background='#ffffff'">
