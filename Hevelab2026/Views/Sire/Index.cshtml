    <!-- Body -->
    <div style="flex: 1; overflow-y: auto; padding: 20px;">
        <p style="font-size: 12.5px; color: var(--cta-text-secondary); margin-bottom: 16px; line-height: 1.5;">
            Los comprobantes que difieren de la propuesta oficial de la SUNAT se resaltan en <span style="background: #fef3c7; color: #b45309; padding: 2px 6px; border-radius: 4px; font-weight: 600;">amarillo</span>. Puede corregir su registro local haciendo clic en "Aceptar Propuesta".
        </p>
        <div style="border: 1px solid var(--cta-border); border-radius: 6px; overflow: hidden;">
            <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 12px;">
                <thead>
                    <tr style="background: #f8fafc; border-bottom: 1px solid var(--cta-border); font-weight: 600; color: var(--cta-text-secondary);">
                        <th style="padding: 10px 12px;">N° Comprobante</th>
                        <th style="padding: 10px 12px; text-align: right;">SUNAT</th>
