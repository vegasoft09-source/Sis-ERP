@model Hevelab2026.Models.RecepcionModel

@{
    ViewData["Title"] = "Detalle de Recepción";
}

@section Styles {
    <link rel="stylesheet" href="~/css/recepciones.css" asp-append-version="true" />
}

<div class="recepciones-container">
    <header class="recepciones-header">
        <div class="header-info">
            <a href="@Url.Action("Index", "RecepcionesView")" style="color: var(--text-muted); text-decoration: none; font-size: 0.9rem; display: inline-block; margin-bottom: 0.5rem;">← Regresar</a>
            <h2 class="text-primary">@Model.Referencia</h2>
        </div>
        <div style="display: flex; gap: 0.5rem;">
            <button class="btn btn-primary" id="btnConfirmarRecepcion">Confirmar</button>
            <button class="btn btn-secondary" onclick="window.print()">Imprimir</button>
        </div>
    </header>

    <section class="filters-card" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; align-items: start;">
        <div>
            <p style="margin: 0.5rem 0;"><strong style="color: var(--text-muted)">Recibir De:</strong> <span style="display:block; font-size: 1.1rem; margin-top:0.25rem">@Model.Desde</span></p>
            <p style="margin: 1.5rem 0 0.5rem 0;"><strong style="color: var(--text-muted)">Tipo de Operación:</strong> <span style="display:block; margin-top:0.25rem">@Model.TipoOperacion</span></p>
            <p style="margin: 1.5rem 0 0.5rem 0;"><strong style="color: var(--text-muted)">Ubicación de Destino:</strong> <span style="display:block; margin-top:0.25rem; color: var(--text-muted)">📍 @Model.UbicacionDestino</span></p>
        </div>
        <div>
            <p style="margin: 0.5rem 0;"><strong style="color: var(--text-muted)">Fecha Programada:</strong> <span style="display:block; margin-top:0.25rem">@Model.FechaProgramada.ToString("dd MMM, h:mm tt")</span></p>
            <p style="margin: 1.5rem 0 0.5rem 0;"><strong style="color: var(--text-muted)">Documento Origen:</strong> <span style="display:block; margin-top:0.25rem; color: #818cf8">@Model.DocumentoOrigen</span></p>
        </div>
    </section>

    <h3 style="margin: 2rem 0 1rem 0;">Operaciones de Productos</h3>
    <main class="table-responsive">
        <table class="recepciones-table">
            <thead>
                <tr>
                    <th>PRODUCTO</th>
                    <th style="text-align: right;">DEMANDA</th>
                    <th style="text-align: right;">CANTIDAD</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var detalle in Model.Detalles)
                {
                    <tr>
                        <td>
                            <strong style="color: var(--text-main)">[@detalle.CodigoProducto] @detalle.NombreProducto</strong>
                            <span style="display: block; font-size: 0.8rem; color: var(--text-muted)">@detalle.DescripcionProducto</span>
                        </td>
                        <td style="text-align: right; font-weight: 600;">@detalle.Demanda.ToString("N2")</td>
                        <td style="text-align: right; color: #818cf8; font-weight: 700;">@detalle.Cantidad.ToString("N2")</td>
                    </tr>
                }
            </tbody>
        </table>
    </main>
</div>