@model Hevelab2026.Models.RecepcionModel

@{
    ViewData["Title"] = "Nuevo Requerimiento de Recepción";
}

@section Styles {
    <link rel="stylesheet" href="~/css/recepciones.css" asp-append-version="true" />
}

<form asp-action="Crear" method="post" class="recepciones-container">
    @Html.AntiForgeryToken()

    <header class="recepciones-header" style="margin-bottom: 1.5rem;">
        <div class="header-info">
            <a href="@Url.Action("Index", "RecepcionesView")" style="color: var(--text-muted); text-decoration: none; font-size: 0.9rem; display: inline-block; margin-bottom: 0.5rem;">← Regresar</a>
            <h2 style="color: var(--primary-color)">Nuevo Requerimiento</h2>
        </div>
        <div style="display: flex; gap: 0.5rem;">
            <button type="submit" class="btn btn-primary">Confirmar orden</button>
            <a href="@Url.Action("Index", "RecepcionesView")" class="btn btn-secondary" style="text-decoration:none; display:inline-block; text-align:center;">Cancelar</a>
        </div>
    </header>

    <div style="display: flex; justify-content: flex-end; margin-bottom: 1.5rem;">
        <div style="background: var(--bg-input); border: 1px solid var(--border-color); border-radius: 0.375rem; display: flex; font-size: 0.75rem; font-weight: 700;">
            <span style="background: #ffffff; color: #0f172a; padding: 0.5rem 1rem; border-radius: 0.375rem 0 0 0.375rem;">SOLICITUD DE COTIZACIÓN</span>
            <span style="color: var(--text-muted); padding: 0.5rem 1rem; border-left: 1px solid var(--border-color);">SOLICITUD ENVIADA</span>
            <span style="color: var(--text-muted); padding: 0.5rem 1rem; border-left: 1px solid var(--border-color);">ORDEN DE COMPRA</span>
        </div>
    </div>

    <section class="filters-card" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; padding: 2rem;">
        <div style="display: flex; flex-direction: column; gap: 1.25rem;">
            <div class="filter-group">
                <label>PROVEEDOR</label>
                <select asp-for="Desde" required>
                    <option value="">Seleccione un proveedor...</option>
                    <option value="Distribuidora Industrial S.A.">Distribuidora Industrial S.A.</option>
                    <option value="AC DC SUPPLY">AC DC SUPPLY</option>
                </select>
            </div>
            <div class="filter-group">
                <label>REFERENCIA DE PROVEEDOR</label>
                <input type="text" asp-for="Nota" placeholder="Ej: REF-8822" />
            </div>
            <div class="filter-group">
                <label>ENTREGAR A</label>
                <input type="text" asp-for="UbicacionDestino" value="Almacén Principal - Lima" />
            </div>
        </div>

        <div style="display: flex; flex-direction: column; gap: 1.25rem;">
            <div class="filter-group">
                <label>FECHA LÍMITE DE LA ORDEN</label>
                <input type="date" asp-for="FechaLimite" required />
            </div>
            <div class="filter-group">
                <label>ENTREGA ESPERADA</label>
                <input type="date" asp-for="FechaProgramada" required />
            </div>
            <div class="filter-group">
                <label>TÉRMINOS DE PAGO</label>
                <select name="terminosPago">
                    <option value="30">30 días netos</option>
                    <option value="0">Pago inmediato</option>
                    <option value="15">15 días netos</option>
                </select>
            </div>
        </div>
    </section>

    <h3 style="margin: 2rem 0 1rem 0; font-size: 1.1rem; letter-spacing: 0.05em; color: var(--text-muted)">DETALLE DE PRODUCTOS Y SERVICIOS</h3>
    <main class="table-responsive">
        <table class="recepciones-table">
            <thead>
                <tr>
                    <th style="width: 60px;">ITEM</th>
                    <th>CÓDIGO / PRODUCTO</th>
                    <th style="text-align: right;">STOCK</th>
                    <th style="text-align: right; width: 120px;">CANTIDAD</th>
                    <th style="text-align: right;">PRECIO UNITARIO</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td style="color: var(--text-muted); font-weight:600;">1</td>
                    <td>
                        <select style="width: 100%; padding: 0.5rem; background: var(--bg-input); border: 1px solid var(--border-color); color: var(--text-main); border-radius: 0.375rem;">
                            <option>[MAT-0092] Vigueta de Acero Estructural (Calibre 14, 6m)</option>
                            <option>[CON-0155] Concreto Premezclado f'c=250</option>
                        </select>
                    </td>
                    <td style="text-align: right; color: var(--text-muted)">150.00</td>
                    <td style="text-align: right;">
                        <input type="number" value="1" style="width: 80px; text-align: right; padding: 0.4rem; background: var(--bg-input); border: 1px solid var(--border-color); color: var(--text-main); border-radius: 0.375rem; font-weight:700;" />
                    </td>
                    <td style="text-align: right; font-weight: 700; color: #818cf8;">$ 1,240.00</td>
                </tr>
            </tbody>
        </table>

        <div style="padding: 1rem; background: rgba(255,255,255,0.01); border-top: 1px solid var(--border-color); display: flex; gap: 1.5rem; font-size: 0.8rem; font-weight: 700; color: var(--primary-color);">
            <span style="cursor:pointer;">➕ AGREGAR UN PRODUCTO</span>
            <span style="cursor:pointer; color: var(--text-muted)">📋 AGREGAR UNA SECCIÓN</span>
            <span style="cursor:pointer; color: var(--text-muted)">📝 AGREGAR UNA NOTA</span>
        </div>
    </main>
</form>