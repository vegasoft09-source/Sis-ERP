<!DOCTYPE html>
<html lang="es" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="HeveLab — Sistema de gestión empresarial" />
    <title>@ViewData["Title"] - HeveLab</title>
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/css/inventario.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <div id="hl-overlay" class="hl-overlay" aria-hidden="true"></div>

    <div class="hl-shell">

        <aside id="hl-sidebar" class="hl-sidebar" role="navigation" aria-label="Navegación principal">

            <div class="hl-sidebar-header">
                <img id="hl-brand-logo"
                     src="~/img/Logos/vission.png"
                     alt="HeveLab logo"
                     class="hl-brand-logo"
                     draggable="false" />

                <span id="hl-brand-name" class="hl-brand-name truncate">HeveLab</span>

                <button id="hl-btn-close" class="hl-sidebar-close" aria-label="Cerrar menú">
                    <svg class="hl-icon" viewBox="0 0 24 24">
                        <line x1="18" y1="6" x2="6" y2="18" />
                        <line x1="6" y1="6" x2="18" y2="18" />
                    </svg>
                </button>

                <button id="hl-btn-toggle" class="hl-sidebar-toggle" aria-label="Colapsar menú">
                    <span id="hl-toggle-icon">
                        <svg class="hl-icon" viewBox="0 0 24 24">
                            <polyline points="15 18 9 12 15 6" />
                        </svg>
                    </span>
                </button>
            </div>

            <nav class="hl-nav">
                <div class="hl-nav-section-label">
                    <span>MAIN</span>
                    <span class="hl-label-line"></span>
                </div>

                <a href="/" class="hl-nav-link" aria-label="Dashboard">
                    <svg class="hl-icon" viewBox="0 0 24 24">
                        <rect x="3" y="3" width="7" height="7" />
                        <rect x="14" y="3" width="7" height="7" />
                        <rect x="3" y="14" width="7" height="7" />
                        <rect x="14" y="14" width="7" height="7" />
                    </svg>
                    <span class="hl-nav-label">Dashboard</span>
                </a>

                <div class="hl-nav-section-label">
                    <span>OPERACIONES</span>
                    <span class="hl-label-line"></span>
                </div>

                <div class="hl-nav-group">
                    <button type="button" class="hl-nav-link hl-nav-parent" id="hl-inventory-toggle" aria-expanded="false">
                        <svg class="hl-icon" viewBox="0 0 24 24">
                            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
                            <polyline points="3.27 6.96 12 12.01 20.73 6.96" />
                            <line x1="12" y1="22.08" x2="12" y2="12" />
                        </svg>

                        <span class="hl-nav-label">Inventario</span>

                        <svg class="hl-icon hl-submenu-arrow" viewBox="0 0 24 24">
                            <polyline points="6 9 12 15 18 9" />
                        </svg>
                    </button>

                    <div class="hl-submenu" id="hl-inventory-submenu">
                        <a asp-controller="RecepcionesView" asp-action="Index" class="hl-submenu-link">Recepciones</a>

                        <a href="#" class="hl-submenu-link">Entregas</a>
                        <a href="#" class="hl-submenu-link">Desechar</a>
                        <a asp-controller="Producto" asp-action="Index" class="hl-submenu-link">Productos</a>
                    </div>
                </div>


                <div class="hl-nav-settings-gap">
                    <div class="hl-nav-section-label">
                        <span>AJUSTES</span>
                        <span class="hl-label-line"></span>
                    </div>

                    <a href="/settings" class="hl-nav-link" aria-label="Configuración">
                        <svg class="hl-icon" viewBox="0 0 24 24">
                            <circle cx="12" cy="12" r="3" />
                            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" />
                        </svg>
                        <span class="hl-nav-label">Configuración</span>
                    </a>
                </div>
            </nav>
        </aside>

        <div class="hl-content">

            <header class="hl-topbar">
                <div class="hl-topbar-left">
                    <button id="hl-btn-menu" class="hl-menu-btn" aria-label="Abrir menú">
                        <svg class="hl-icon hl-icon-lg" viewBox="0 0 24 24">
                            <line x1="3" y1="12" x2="21" y2="12" />
                            <line x1="3" y1="6" x2="21" y2="6" />
                            <line x1="3" y1="18" x2="21" y2="18" />
                        </svg>
                    </button>

                    <nav class="hl-breadcrumb" aria-label="Breadcrumb">
                        @if (ViewData["Breadcrumbs"] != null)
                        {
                            var crumbs = (IEnumerable<(string Label, string Url)>)ViewData["Breadcrumbs"]!;
                            var crumbList = crumbs.ToList();
                            for (int i = 0; i < crumbList.Count; i++)
                            {
                                var crumb = crumbList[i];
                                bool isLast = i == crumbList.Count - 1;
                                if (isLast)
                                {
                                    <span class="hl-breadcrumb-current" aria-current="page">@crumb.Label</span>
                                }
                                else
                                {
                                    <a href="@crumb.Url">@crumb.Label</a>
                                    <span class="hl-breadcrumb-sep" aria-hidden="true">&rsaquo;</span>
                                }
                            }
                        }
                        else
                        {
                            <span class="hl-breadcrumb-current" aria-current="page">
                                @(ViewData["Title"] ?? "HeveLab")
                            </span>
                        }
                    </nav>
                </div>

                <div class="hl-topbar-right">

                    <div class="hl-clock" aria-label="Hora actual" aria-live="polite">
                        <svg class="hl-clock-icon hl-icon" viewBox="0 0 24 24">
                            <circle cx="12" cy="12" r="10" />
                            <polyline points="12 6 12 12 16 14" />
                        </svg>
                        <span id="hl-clock-time">--:--:--</span>
                    </div>

                    <button id="hl-btn-theme" class="hl-icon-btn" title="Cambiar tema" aria-label="Cambiar tema">
                        <span id="hl-theme-icon">
                            <svg class="hl-icon hl-icon-lg" viewBox="0 0 24 24">
                                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
                            </svg>
                        </span>
                    </button>

                    <button class="hl-icon-btn" aria-label="Notificaciones">
                        <svg class="hl-icon hl-icon-lg" viewBox="0 0 24 24">
                            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                            <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                        </svg>
                        <span class="hl-notif-dot" aria-hidden="true"></span>
                    </button>

                    <div class="hl-topbar-divider" aria-hidden="true"></div>

                    <div class="hl-profile-wrap" id="hl-profile-wrap">
                        <button id="hl-profile-btn" class="hl-profile-btn" aria-label="Menú de usuario" aria-haspopup="true" aria-expanded="false">
                            <div class="hl-profile-info">
                                <span class="hl-profile-name">@(User?.Identity?.Name ?? "Usuario")</span>
                                <span class="hl-profile-role">Administrador</span>
                            </div>
                            <div class="hl-avatar" aria-hidden="true">
                                <svg class="hl-icon" viewBox="0 0 24 24">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                    <circle cx="12" cy="7" r="4" />
                                </svg>
                            </div>
                        </button>

                        <div id="hl-profile-dropdown" class="hl-profile-dropdown" role="menu" aria-label="Menú de usuario">
                            <div class="hl-dropdown-header">
                                <div class="name">@(User?.Identity?.Name ?? "Usuario")</div>
                                <div class="role">Administrador</div>
                            </div>
                            <div class="hl-dropdown-body">
                                <a href="/settings?tab=profile" class="hl-dropdown-item" role="menuitem">
                                    <svg class="hl-icon" viewBox="0 0 24 24">
                                        <circle cx="12" cy="12" r="3" />
                                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" />
                                    </svg>
                                    Ajustes
                                </a>
                                <button id="hl-btn-logout" class="hl-dropdown-item danger" role="menuitem">
                                    <svg class="hl-icon" viewBox="0 0 24 24">
                                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                                        <polyline points="16 17 21 12 16 7" />
                                        <line x1="21" y1="12" x2="9" y2="12" />
                                    </svg>
                                    Cerrar sesión
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </header>

            <main class="hl-main" role="main">
                @RenderBody()
            </main>

        </div>
    </div>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/inventario.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>