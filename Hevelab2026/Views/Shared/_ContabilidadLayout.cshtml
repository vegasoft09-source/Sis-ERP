<!DOCTYPE html>
<html lang="es" data-layout="contabilidad">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="HeveLab — Área de Contabilidad" />
    <title>@ViewData["Title"] - Contabilidad - HeveLab</title>
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Estilos de Contabilidad (Encapsulados para forzar el tema claro) -->
    <style>
        :root {
            --cta-bg: #f4f6fb;
            --cta-sidebar-bg: #ffffff;
            --cta-header-bg: #ffffff;
            --cta-primary: #3b5bdb;
            --cta-primary-hover: #2b49c4;
            --cta-primary-soft: rgba(59, 93, 219, 0.08);
            --cta-text-primary: #1e293b;
            --cta-text-secondary: #475569;
            --cta-text-muted: #94a3b8;
            --cta-border: #e2e8f0;
            --cta-sidebar-w: 240px;
            --cta-header-h: 64px;
            --cta-radius: 10px;
            --cta-transition: 200ms cubic-bezier(0.4, 0, 0.2, 1);
            --cta-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.05), 0 1px 2px -1px rgba(0, 0, 0, 0.05);
            --cta-shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -2px rgba(0, 0, 0, 0.05);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background-color: var(--cta-bg) !important;
            color: var(--cta-text-primary) !important;
            height: 100vh;
            overflow: hidden;
            display: flex;
        }

        /* Variables CSS overrides para las vistas embebidas */
        .cta-wrapper {
            --bg-app: var(--cta-bg);
            --bg-sidebar: var(--cta-sidebar-bg);
            --bg-topbar: var(--cta-header-bg);
            --bg-main: var(--cta-bg);
            --text-primary: var(--cta-text-primary);
            --text-secondary: var(--cta-text-secondary);
            --text-muted: var(--cta-text-muted);
            --border-color: var(--cta-border);
            --sys-primary: var(--cta-primary);
            --sys-primary-hover: var(--cta-primary-hover);
            --sys-soft: var(--cta-primary-soft);
            --radius-lg: var(--cta-radius);
            --shadow-sm: var(--cta-shadow);
            --shadow-md: var(--cta-shadow-md);
            
            width: 100%;
            height: 100vh;
            display: flex;
            position: relative;
        }

        /* --- Sidebar --- */
        .cta-sidebar {
            width: var(--cta-sidebar-w);
            background-color: var(--cta-sidebar-bg);
            border-right: 1px solid var(--cta-border);
            display: flex;
            flex-direction: column;
            height: 100%;
            position: fixed;
            left: 0;
            top: 0;
            bottom: 0;
            z-index: 100;
            transition: transform var(--cta-transition);
        }

        .cta-sidebar-header {
            height: var(--cta-header-h);
            padding: 0 24px;
            display: flex;
            align-items: center;
            gap: 12px;
            border-bottom: 1px solid var(--cta-border);
        }

        .cta-logo {
            width: 28px;
            height: 28px;
            border-radius: 6px;
        }

        .cta-brand {
            font-size: 16px;
            font-weight: 700;
            color: var(--cta-text-primary);
            letter-spacing: -0.01em;
        }

        .cta-nav {
            flex: 1;
            padding: 24px 16px;
            display: flex;
            flex-direction: column;
            gap: 6px;
            overflow-y: auto;
        }

        .cta-nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 14px;
            color: var(--cta-text-secondary);
            text-decoration: none;
            font-size: 13.5px;
            font-weight: 500;
            border-radius: var(--cta-radius);
            transition: background var(--cta-transition), color var(--cta-transition);
        }

        .cta-nav-link svg {
            width: 18px;
            height: 18px;
            stroke-width: 2;
            fill: none;
            stroke: currentColor;
            transition: stroke var(--cta-transition);
        }

        .cta-nav-link:hover {
            background-color: #f8fafc;
            color: var(--cta-text-primary);
        }

        .cta-nav-link.active {
            background-color: var(--cta-primary-soft);
            color: var(--cta-primary);
            font-weight: 600;
        }

        .cta-sidebar-footer {
            padding: 16px;
            border-top: 1px solid var(--cta-border);
        }

        .cta-btn-back {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            width: 100%;
            padding: 10px;
            border: 1px solid var(--cta-border);
            border-radius: var(--cta-radius);
            color: var(--cta-text-secondary);
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
            transition: background var(--cta-transition), color var(--cta-transition);
        }

        .cta-btn-back:hover {
            background-color: #f8fafc;
            color: var(--cta-text-primary);
        }

        /* --- Content Area --- */
        .cta-main-container {
            flex: 1;
            margin-left: var(--cta-sidebar-w);
            display: flex;
            flex-direction: column;
            height: 100%;
            min-width: 0;
            transition: margin-left var(--cta-transition);
        }

        /* --- Header --- */
        .cta-header {
            height: var(--cta-header-h);
            background-color: var(--cta-header-bg);
            border-bottom: 1px solid var(--cta-border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 32px;
            z-index: 90;
        }

        .cta-header-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .cta-menu-btn {
            display: none;
            background: none;
            border: none;
            color: var(--cta-text-secondary);
            cursor: pointer;
            padding: 4px;
            border-radius: 6px;
            transition: background var(--cta-transition);
        }

        .cta-menu-btn:hover {
            background-color: var(--cta-primary-soft);
            color: var(--cta-primary);
        }

        .cta-menu-btn svg {
            width: 20px;
            height: 20px;
            stroke-width: 2;
            fill: none;
            stroke: currentColor;
        }

        .cta-title-area {
            display: flex;
            flex-direction: column;
        }

        .cta-area-title {
            font-size: 15px;
            font-weight: 700;
            color: var(--cta-text-primary);
        }

        .cta-breadcrumb {
            font-size: 12px;
            color: var(--cta-text-muted);
            display: flex;
            align-items: center;
            gap: 4px;
            margin-top: 2px;
        }

        .cta-breadcrumb a {
            color: var(--cta-text-muted);
            text-decoration: none;
            transition: color var(--cta-transition);
        }

        .cta-breadcrumb a:hover {
            color: var(--cta-primary);
        }

        .cta-header-right {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .cta-badge {
            background-color: var(--cta-primary-soft);
            color: var(--cta-primary);
            font-size: 11px;
            font-weight: 600;
            padding: 4px 10px;
            border-radius: 9999px;
            border: 1px solid rgba(59, 93, 219, 0.15);
        }

        /* --- Scrollable Content --- */
        .cta-content {
            flex: 1;
            padding: 32px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        /* --- Footer --- */
        .cta-footer {
            border-top: 1px solid var(--cta-border);
            padding: 16px 0 0 0;
            margin-top: 32px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 12px;
            color: var(--cta-text-muted);
        }

        .cta-footer-links {
            display: flex;
            gap: 16px;
        }

        .cta-footer-links a {
            color: var(--cta-text-muted);
            text-decoration: none;
            transition: color var(--cta-transition);
        }

        .cta-footer-links a:hover {
            color: var(--cta-text-secondary);
        }

        /* --- Mobile Overlay --- */
        .cta-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background-color: rgba(30, 41, 59, 0.4);
            backdrop-filter: blur(4px);
            z-index: 95;
        }

        /* --- Responsive media queries --- */
        @@media (max-width: 1023px) {
            .cta-sidebar {
                transform: translateX(-100%);
            }
            
            .cta-sidebar.open {
                transform: translateX(0);
            }

            .cta-main-container {
                margin-left: 0;
            }

            .cta-menu-btn {
                display: block;
            }

            .cta-header {
                padding: 0 20px;
            }

            .cta-content {
                padding: 20px;
            }

            .cta-overlay.active {
                display: block;
            }
        }
    </style>
</head>
<body>

    <div class="cta-wrapper">
        
        <!-- Mobile Overlay -->
        <div id="cta-overlay" class="cta-overlay"></div>

        <!-- ═══════════ SIDEBAR CONTABILIDAD ═══════════ -->
        <aside id="cta-sidebar" class="cta-sidebar">
            
            <div class="cta-sidebar-header">
                <!-- Mini Logo -->
                <svg viewBox="0 0 24 24" style="width: 24px; height: 24px; fill: none; stroke: var(--cta-primary); stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round;">
                    <path d="M3 3h18v18H3z"/>
                    <path d="M21 9H3M21 15H3M12 3v18"/>
                </svg>
                <span class="cta-brand">Contabilidad</span>
            </div>

            <nav class="cta-nav">
                
                <!-- Facturas -->
                <a href="/Facturas" class="cta-nav-link" id="nav-facturas">
                    <svg viewBox="0 0 24 24">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                        <polyline points="14 2 14 8 20 8"></polyline>
                        <line x1="16" y1="13" x2="8" y2="13"></line>
                        <line x1="16" y1="17" x2="8" y2="17"></line>
                        <polyline points="10 9 9 9 8 9"></polyline>
                    </svg>
                    <span>Facturas</span>
                </a>

                <!-- Libro Mayor -->
                <a href="/LibroMayor" class="cta-nav-link" id="nav-libromayor">
                    <svg viewBox="0 0 24 24">
                        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                        <line x1="8" y1="6" x2="16" y2="6"></line>
                        <line x1="8" y1="11" x2="16" y2="11"></line>
                    </svg>
                    <span>Libro Mayor</span>
                </a>

                <!-- SIRE -->
                <a href="/Sire" class="cta-nav-link" id="nav-sire">
                    <svg viewBox="0 0 24 24">
                        <line x1="18" y1="20" x2="18" y2="10"></line>
                        <line x1="12" y1="20" x2="12" y2="4"></line>
                        <line x1="6" y1="20" x2="6" y2="14"></line>
                    </svg>
                    <span>SIRE</span>
                </a>

                <!-- Documentos -->
                <a href="/Documentos" class="cta-nav-link" id="nav-documentos">
                    <svg viewBox="0 0 24 24">
                        <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
                    </svg>
                    <span>Documentos</span>
                </a>

            </nav>

            <div class="cta-sidebar-footer">
                <a href="/" class="cta-btn-back">
                    <svg viewBox="0 0 24 24" style="width: 14px; height: 14px; fill: none; stroke: currentColor; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round;">
                        <polyline points="15 18 9 12 15 6"></polyline>
                    </svg>
                    Volver al ERP
                </a>
            </div>

        </aside>

        <!-- ═══════════ CONTENT AREA ═══════════ -->
        <div class="cta-main-container">
            
            <!-- Header superior -->
            <header class="cta-header">
                <div class="cta-header-left">
                    <!-- Hamburger Menu Button (mobile only) -->
                    <button id="cta-menu-btn" class="cta-menu-btn" aria-label="Menu">
                        <svg viewBox="0 0 24 24">
                            <line x1="3" y1="12" x2="21" y2="12"></line>
                            <line x1="3" y1="6" x2="21" y2="6"></line>
                            <line x1="3" y1="18" x2="21" y2="18"></line>
                        </svg>
                    </button>

                    <!-- Breadcrumbs -->
                    <div class="cta-title-area">
                        <span class="cta-area-title">Módulo de Contabilidad</span>
                        <div class="cta-breadcrumb">
                            <a href="/">Dashboard</a>
                            <span>&rsaquo;</span>
                            <span style="color: var(--cta-text-secondary); font-weight: 500;">@ViewData["Title"]</span>
                        </div>
                    </div>
                </div>

                <div class="cta-header-right">
                    <span class="cta-badge">Ejercicio Activo 2026</span>
                </div>
            </header>

            <!-- Render Body -->
            <main class="cta-content">
                
                <div>
                    @RenderBody()
                </div>

                <!-- Footer -->
                <footer class="cta-footer">
                    <span>&copy; 2026 HeveLab. Módulo de Contabilidad Empresarial.</span>
                    <div class="cta-footer-links">
                        <a href="/">ERP Home</a>
                        <a href="/settings">Ajustes</a>
                    </div>
                </footer>

            </main>

        </div>

    </div>

    <!-- Toggle scripts for responsiveness and active class -->
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // Sidebar Mobile Toggle
            var menuBtn = document.getElementById("cta-menu-btn");
            var sidebar = document.getElementById("cta-sidebar");
            var overlay = document.getElementById("cta-overlay");

            if (menuBtn && sidebar && overlay) {
                menuBtn.addEventListener("click", function() {
                    sidebar.classList.add("open");
                    overlay.classList.add("active");
                });

                overlay.addEventListener("click", function() {
                    sidebar.classList.remove("open");
                    overlay.classList.remove("active");
                });
            }

            // Set active class in sidebar based on current URL path
            var path = window.location.pathname.toLowerCase();
            var links = {
                "facturas": document.getElementById("nav-facturas"),
                "libromayor": document.getElementById("nav-libromayor"),
                "sire": document.getElementById("nav-sire"),
                "documentos": document.getElementById("nav-documentos")
            };

            for (var key in links) {
                if (links[key]) {
                    links[key].classList.remove("active");
                }
            }

            if (path.includes("/facturas")) {
                if (links["facturas"]) links["facturas"].classList.add("active");
            } else if (path.includes("/libromayor")) {
                if (links["libromayor"]) links["libromayor"].classList.add("active");
            } else if (path.includes("/sire")) {
                if (links["sire"]) links["sire"].classList.add("active");
            } else if (path.includes("/documentos")) {
                if (links["documentos"]) links["documentos"].classList.add("active");
            }
        });
    </script>
</body>
</html>
