@{
    ViewData["Title"] = "Cotizaciones";
    ViewData["Breadcrumbs"] = new[] {
        ("Dashboard", "/"),
        ("Ventas", "#"),
        ("Cotizaciones", "/Cotizaciones")
    };
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/cotizaciones.css" />
}

<div class="container mt-4">

    <!-- TITULO -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">Cotizaciones</h2>
            <p class="text-muted">
                Gestiona y realiza seguimiento a tus propuestas comerciales.
            </p>
        </div>

        <a asp-controller="Cotizaciones" asp-action="Create" class="btn btn-primary px-4">

            <i class="bi bi-plus-lg"></i>
            Nuevo

        </a>
    </div>

    <!-- FILTROS -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">

            <form asp-action="Index" method="get">

                <div class="row g-3">

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">
                            Rango de fecha
                        </label>

                        <input type="date" class="form-control" name="fecha">
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">
                            Cliente / Razón Social
                        </label>

                        <input type="text" class="form-control" placeholder="Buscar cliente..." name="cliente">
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-semibold">
                            Estado
                        </label>

                        <select class="form-select" name="estado">
                            <option>Todos los estados</option>
                            <option>Pendiente</option>
                            <option>Aprobado</option>
                            <option>Rechazado</option>
                        </select>
                    </div>

                    <div class="col-md-1 d-flex align-items-end">
                        <button class="btn btn-dark w-100">
                            Filtrar
                        </button>
                    </div>

                </div>

            </form>

        </div>
    </div>

    <!-- TABLA -->
    <div class="card shadow-sm">

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-light">
                        <tr>
                            <th>N° Pedido</th>
                            <th>Fecha</th>
                            <th>Cliente</th>
                            <th>Razón Social</th>
                            <th>RUC</th>
                            <th>Subtotal</th>
                            <th>Total</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr>

                                <td>@item.NumeroPedido</td>

                                <td>
                                    @item.FechaCreacion.ToShortDateString()
                                </td>

                                <td>@item.Cliente</td>

                                <td>@item.RazonSocial</td>

                                <td>@item.RUC</td>

                                <td>S/. @item.Subtotal</td>

                                <td class="fw-bold">
                                    S/. @item.Total
                                </td>

                                <td>

                                    @if (item.Estado == "Pendiente")
                                    {
                                        <span class="badge bg-warning text-dark">
                                            Pendiente
                                        </span>
                                    }
                                    else if (item.Estado == "Aprobado")
                                    {
                                        <span class="badge bg-success">
                                            Aprobado
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">
                                            Rechazado
                                        </span>
                                    }

                                </td>

                                <td>

                                    <td class="d-flex gap-2">

                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">

                                            <i class="bi bi-eye"></i>

                                        </a>

                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">

                                            <i class="bi bi-pencil-square"></i>

                                        </a>

                                    </td>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>