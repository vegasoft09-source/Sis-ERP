@model Hevelab2026.Models.Cotizacion

@{
    ViewData["Title"] = "Editar Cotización";
    ViewData["Breadcrumbs"] = new[] {
        ("Dashboard", "/"),
        ("Ventas", "#"),
        ("Cotizaciones", "/Cotizaciones"),
        ($"Editar {Model.NumeroPedido}", "")
    };
}

<div class="frm-wrap">
    <div class="frm-header mb-4">
        <a href="/Cotizaciones" class="frm-back">
            <svg viewBox="0 0 24 24"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Volver
        </a>
        <div>
            <h1 class="frm-title">Editar Cotización</h1>
            <p class="frm-subtitle">Actualiza los datos de la cotización @Model.NumeroPedido</p>
        </div>
    </div>

    <form method="post" action="/Cotizaciones/Edit">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model.Id" />
        <input type="hidden" name="NumeroPedido" value="@Model.NumeroPedido" />
        
        <div class="frm-card mb-4">
            <div class="frm-card-head">
                <span class="frm-card-num">1</span>
                Datos del Cliente
            </div>
            <div class="frm-card-body">
                <div class="frm-grid">
                    <div class="frm-field frm-field--half">
                        <label class="frm-label">Cliente</label>
                        <input type="text" name="Cliente" class="frm-input" value="@Model.Cliente" required />
                    </div>
                    <div class="frm-field frm-field--half">
                        <label class="frm-label">Razón Social</label>
                        <input type="text" name="RazonSocial" class="frm-input" value="@Model.RazonSocial" />
                    </div>
                    <div class="frm-field frm-field--half">
                        <label class="frm-label">RUC</label>
                        <input type="text" name="RUC" class="frm-input" value="@Model.RUC" />
                    </div>
                </div>
            </div>
        </div>

        <div class="frm-card mb-4">
            <div class="frm-card-head">
                <span class="frm-card-num">2</span>
                Condiciones Comerciales
            </div>
            <div class="frm-card-body">
                <div class="frm-grid">
                    <div class="frm-field frm-field--third">
                        <label class="frm-label">Moneda</label>
                        <select name="Moneda" class="frm-input frm-select">
                            @if (Model.Moneda == "PEN") { <option value="PEN" selected>Soles (PEN)</option> } else { <option value="PEN">Soles (PEN)</option> }
                            @if (Model.Moneda == "USD") { <option value="USD" selected>Dólares (USD)</option> } else { <option value="USD">Dólares (USD)</option> }
                        </select>
                    </div>
                    <div class="frm-field frm-field--third">
                        <label class="frm-label">Condición de Pago</label>
                        <select name="CondicionPago" class="frm-input frm-select">
                            @if (Model.CondicionPago == "Contado") { <option value="Contado" selected>Contado</option> } else { <option value="Contado">Contado</option> }
                            @if (Model.CondicionPago == "Crédito 15 días") { <option value="Crédito 15 días" selected>Crédito 15 días</option> } else { <option value="Crédito 15 días">Crédito 15 días</option> }
                            @if (Model.CondicionPago == "Crédito 30 días") { <option value="Crédito 30 días" selected>Crédito 30 días</option> } else { <option value="Crédito 30 días">Crédito 30 días</option> }
                            @if (Model.CondicionPago == "Crédito 60 días") { <option value="Crédito 60 días" selected>Crédito 60 días</option> } else { <option value="Crédito 60 días">Crédito 60 días</option> }
                        </select>
                    </div>
                    <div class="frm-field frm-field--third">
                        <label class="frm-label">Vendedor</label>
                        <input type="text" name="Vendedor" class="frm-input" value="@Model.Vendedor" />
                    </div>
                </div>
            </div>
        </div>

        <div class="frm-card mb-4">
            <div class="frm-card-head">
                <span class="frm-card-num">3</span>
                Montos y Totales
            </div>
            <div class="frm-card-body">
                <div class="frm-grid">
                    <div class="frm-field frm-field--third">
                        <label class="frm-label">Subtotal</label>
                        <input type="number" name="Subtotal" class="frm-input" step="0.01" value="@Model.Subtotal.ToString(System.Globalization.CultureInfo.InvariantCulture)" />
                    </div>
                    <div class="frm-field frm-field--third">
                        <label class="frm-label">Descuento</label>
                        <input type="number" name="Descuento" class="frm-input" step="0.01" value="@Model.Descuento.ToString(System.Globalization.CultureInfo.InvariantCulture)" />
                    </div>
                    <div class="frm-field frm-field--third">
                        <label class="frm-label">Impuestos</label>
                        <input type="number" name="Impuestos" class="frm-input" step="0.01" value="@Model.Impuestos.ToString(System.Globalization.CultureInfo.InvariantCulture)" />
                    </div>
                    <div class="frm-field frm-field--third">
                        <label class="frm-label">Total</label>
                        <input type="number" name="Total" class="frm-input" step="0.01" value="@Model.Total.ToString(System.Globalization.CultureInfo.InvariantCulture)" />
                    </div>
                    <div class="frm-field frm-field--third">
                        <label class="frm-label">Estado</label>
                        <select name="Estado" class="frm-input frm-select">
                            @if (Model.Estado == "Pendiente") { <option value="Pendiente" selected>Pendiente</option> } else { <option value="Pendiente">Pendiente</option> }
                            @if (Model.Estado == "Aprobado") { <option value="Aprobado" selected>Aprobado</option> } else { <option value="Aprobado">Aprobado</option> }
                            @if (Model.Estado == "Rechazado") { <option value="Rechazado" selected>Rechazado</option> } else { <option value="Rechazado">Rechazado</option> }
                        </select>
                    </div>
                    <div class="frm-field frm-field--full">
                        <label class="frm-label">Notas</label>
                        <input type="text" name="Notas" class="frm-input" value="@Model.Notas" />
                    </div>
                </div>
            </div>
        </div>

        <div class="frm-actions mb-5">
            <a href="/Cotizaciones" class="frm-btn-cancel">Cancelar</a>
            <button type="submit" class="frm-btn-save">
                <svg viewBox="0 0 24 24"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                Guardar cambios
            </button>
        </div>
    </form>
</div>