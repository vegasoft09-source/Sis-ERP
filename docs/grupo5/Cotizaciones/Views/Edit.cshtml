@model Hevelab2026.Models.Cotizacion

@{
    ViewData["Title"] = "Editar Cotización";
    ViewData["Breadcrumbs"] = new[] {
        ("Dashboard", "/"),
        ("Ventas", "#"),
        ("Cotizaciones", "/Cotizaciones")
    };
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/cotizaciones.css" />
}

<div class="container mt-5">

    <div class="card shadow-lg border-0">

        <div class="card-header bg-warning p-4">

            <h2>
                <i class="bi bi-pencil-square"></i>
                Editar Cotización
            </h2>

        </div>

        <div class="card-body p-5">

            <form asp-action="Edit">

                <input type="hidden" asp-for="Id" />

                <div class="row">

                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-bold">
                            Cliente
                        </label>

                        <input asp-for="Cliente"
                               class="form-control form-control-lg" />
                    </div>

                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-bold">
                            Razón Social
                        </label>

                        <input asp-for="RazonSocial"
                               class="form-control form-control-lg" />
                    </div>

                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-bold">
                            RUC
                        </label>

                        <input asp-for="RUC"
                               class="form-control form-control-lg" />
                    </div>

                    <div class="col-md-3 mb-4">
                        <label class="form-label fw-bold">
                            Subtotal
                        </label>

                        <input asp-for="Subtotal"
                               class="form-control form-control-lg" />
                    </div>

                    <div class="col-md-3 mb-4">
                        <label class="form-label fw-bold">
                            Total
                        </label>

                        <input asp-for="Total"
                               class="form-control form-control-lg" />
                    </div>

                    <div class="col-md-6 mb-4">

                        <label class="form-label fw-bold">
                            Estado
                        </label>

                        <select asp-for="Estado"
                                class="form-select form-select-lg">

                            <option>Pendiente</option>
                            <option>Aprobado</option>
                            <option>Rechazado</option>

                        </select>

                    </div>

                </div>

                <div class="mt-4">

                    <button class="btn btn-success btn-lg">

                        <i class="bi bi-check-circle"></i>
                        Guardar Cambios

                    </button>

                    <a asp-action="Index"
                       class="btn btn-secondary btn-lg">

                        Cancelar

                    </a>

                </div>

            </form>

        </div>

    </div>

</div>