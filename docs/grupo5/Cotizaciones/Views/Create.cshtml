@model Hevelab2026.Models.Cotizacion

@{
    ViewData["Title"] = "Nueva Cotización";
    ViewData["Breadcrumbs"] = new[] {
        ("Dashboard", "/"),
        ("Ventas", "#"),
        ("Cotizaciones", "/Cotizaciones")
    };
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/cotizaciones.css" />
}

<div class="container mt-5">

    <div class="card shadow-lg border-0">

        <div class="card-header bg-primary text-white p-4">
            <h2>
                <i class="bi bi-file-earmark-plus"></i>
                Nueva Cotización
            </h2>
        </div>

        <div class="card-body p-4">

            <form asp-action="Create">

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Cliente</label>
                        <input asp-for="Cliente"
                               class="form-control form-control-lg" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Razón Social</label>
                        <input asp-for="RazonSocial"
                               class="form-control form-control-lg" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">RUC</label>
                        <input asp-for="RUC"
                               class="form-control form-control-lg" />
                    </div>

                    <div class="col-md-3 mb-3">
                        <label class="form-label">Subtotal</label>
                        <input asp-for="Subtotal"
                               class="form-control form-control-lg" />
                    </div>

                    <div class="col-md-3 mb-3">
                        <label class="form-label">Total</label>
                        <input asp-for="Total"
                               class="form-control form-control-lg" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Estado</label>

                        <select asp-for="Estado"
                                class="form-select form-select-lg">

                            <option>Pendiente</option>
                            <option>Aprobado</option>
                            <option>Rechazado</option>

                        </select>
                    </div>

                </div>

                <div class="mt-4">

                    <button class="btn btn-primary btn-lg">
                        <i class="bi bi-save"></i>
                        Guardar
                    </button>

                    <a asp-action="Index"
                       class="btn btn-secondary btn-lg">
                        Cancelar
                    </a>

                </div>

            </form>

        </div>

    </div>

</div>