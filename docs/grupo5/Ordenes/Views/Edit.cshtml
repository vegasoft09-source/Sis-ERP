@model Hevelab2026.Models.OrdenVenta

@{
    ViewData["Title"] = "Editar Orden";
    ViewData["Breadcrumbs"] = new[] {
        ("Dashboard", "/"),
        ("Ventas", "#"),
        ("Órdenes", "/Ordenes")
    };
}

@section Styles {
    <link rel="stylesheet" href="~/css/ordenes.css" />
}

<div class="ordenes-container">

    <div class="ordenes-header">
        <div>
            <h1>Editar Orden</h1>
            <p>Modifica los datos de la orden seleccionada.</p>
        </div>

        <a href="/Ordenes" class="btn-secundario">
            Volver
        </a>
    </div>

    <form asp-action="Edit" method="post" class="form-card">

        <div class="form-grid">

            <div class="form-grupo">
                <label>Número de pedido</label>
                <input asp-for="NumeroPedido" readonly />
            </div>

            <div class="form-grupo">
                <label>Fecha de creación</label>
                <input asp-for="FechaCreacion" required />
            </div>

            <div class="form-grupo">
                <label>Cliente</label>
                <input asp-for="Cliente" required />
            </div>

            <div class="form-grupo">
                <label>Razón Social</label>
                <input asp-for="RazonSocial" required />
            </div>

            <div class="form-grupo">
                <label>RUC</label>
                <input asp-for="Ruc" required />
            </div>

            <div class="form-grupo">
                <label>Subtotal</label>
                <input asp-for="Subtotal" type="number" step="0.01" required />
            </div>

            <div class="form-grupo">
                <label>Total</label>
                <input asp-for="Total" type="number" step="0.01" required />
            </div>

            <div class="form-grupo">
                <label>Estado</label>
                <select asp-for="Estado" required>
                    <option value="BORRADOR">BORRADOR</option>
                    <option value="POR FACTURAR">POR FACTURAR</option>
                    <option value="FACTURADO POR COMPLETO">FACTURADO POR COMPLETO</option>
                </select>
            </div>

        </div>

        <div class="form-actions">
            <a href="/Ordenes" class="btn-secundario">
                Cancelar
            </a>

            <button type="submit" class="btn-nuevo">
                Guardar cambios
            </button>
        </div>

    </form>

</div>