@using Hevelab2026.Models
@{
    ViewData["Title"] = "Clientes";
    // El breadcrumb ya viene establecido del controlador
}

<div class="container-fluid p-0">
    <!-- Header Panel -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0" style="color: var(--text-primary); font-weight: 700;">Clientes</h1>
            <p class="mb-0" style="color: var(--text-secondary); font-size: 0.875rem;">Administración y catálogo de clientes del ERP</p>
        </div>
        <a href="/Clientes/Formulario" class="btn d-flex align-items-center gap-2" style="background: var(--sys-primary); color: var(--sys-on-primary); border: none; font-weight: 500; padding: 0.5rem 1.25rem; border-radius: 6px;">
            <svg class="hl-icon" viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            Nuevo Cliente
        </a>
    </div>

    <!-- Filters Card -->
    <div class="card shadow-sm border mb-4" style="border-radius: 8px;">
        <div class="card-body p-3">
            <form method="get" action="/Clientes" class="row g-3">
                <div class="col-md-7">
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0" style="border-color: var(--border-color); color: var(--text-secondary);">
                            <svg class="hl-icon" viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="11" cy="11" r="8"></circle>
                                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                            </svg>
                        </span>
                        <input type="text" id="busquedaInput" class="form-control border-start-0 ps-0" name="busqueda" placeholder="Buscar por Razón Social o N° Documento..." value="@ViewBag.Busqueda" style="border-color: var(--border-color); color: var(--text-primary); outline: none;" />
                    </div>
                </div>
                <div class="col-md-3">
                    <select class="form-select" name="estado" style="border-color: var(--border-color); color: var(--text-primary);" onchange="this.form.submit()">
                        <option value="">Todos los estados</option>
                        @if (ViewBag.Estado == "activo")
                        {
                            <option value="activo" selected>Activo</option>
                        }
                        else
                        {
                            <option value="activo">Activo</option>
                        }
                        @if (ViewBag.Estado == "inactivo")
                        {
                            <option value="inactivo" selected>Inactivo</option>
                        }
                        else
                        {
                            <option value="inactivo">Inactivo</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 d-grid">
                    <button type="submit" class="btn btn-outline-secondary" style="border-color: var(--border-color); color: var(--text-primary);">
                        Filtrar
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Table Card -->
    <div class="card shadow-sm border" style="border-radius: 8px; overflow: hidden;">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="tablaClientes">
                <thead class="table-light" style="background-color: var(--bg-app); border-bottom: 2px solid var(--border-color);">
                    <tr>
                        <th class="ps-4" style="color: var(--text-secondary); font-weight: 600;">Código</th>
                        <th style="color: var(--text-secondary); font-weight: 600;">Razón Social</th>
                        <th style="color: var(--text-secondary); font-weight: 600;">Tipo Doc.</th>
                        <th style="color: var(--text-secondary); font-weight: 600;">N° Documento</th>
                        <th style="color: var(--text-secondary); font-weight: 600;">Teléfono</th>
                        <th style="color: var(--text-secondary); font-weight: 600;">Ciudad</th>
                        <th style="color: var(--text-secondary); font-weight: 600;">Estado</th>
                        <th class="pe-4 text-end" style="color: var(--text-secondary); font-weight: 600; width: 220px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.Clientes != null && ((List<Cliente>)ViewBag.Clientes).Count > 0)
                    {
                        foreach (var cliente in (List<Cliente>)ViewBag.Clientes)
                        {
                            <tr class="cliente-row" data-razon="@cliente.RazonSocial" data-documento="@cliente.NumeroDocumento">
                                <td class="ps-4 font-monospace fw-bold" style="color: var(--sys-primary);">@cliente.Codigo</td>
                                <td class="fw-semibold text-truncate" style="max-width: 250px;">@cliente.RazonSocial</td>
                                <td>@cliente.TipoDocumento</td>
                                <td>@cliente.NumeroDocumento</td>
                                <td>@(!string.IsNullOrEmpty(cliente.Telefono) ? cliente.Telefono : "-")</td>
                                <td>@cliente.Ciudad</td>
                                <td>
                                    @if (cliente.Activo)
                                    {
                                        <span class="badge" style="background-color: var(--sys-primary); color: white; padding: 0.35em 0.65em; font-size: 0.75rem;">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary" style="padding: 0.35em 0.65em; font-size: 0.75rem;">Inactivo</span>
                                    }
                                </td>
                                <td class="pe-4 text-end">
                                    <div class="d-inline-flex gap-1">
                                        <a href="/Clientes/Detalle/@cliente.Id" class="btn btn-sm btn-outline-secondary py-1 px-2" style="font-size: 0.8125rem;">
                                            Ver
                                        </a>
                                        <a href="/Clientes/Formulario/@cliente.Id" class="btn btn-sm btn-outline-secondary py-1 px-2" style="font-size: 0.8125rem;">
                                            Editar
                                        </a>
                                        <form method="post" action="/Clientes/ToggleEstado" class="form-toggle-estado d-inline m-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@cliente.Id" />
                                            <button type="submit" class="btn btn-sm py-1 px-2 @(cliente.Activo ? "btn-outline-danger" : "btn-outline-success")" style="font-size: 0.8125rem;">
                                                @(cliente.Activo ? "Desactivar" : "Activar")
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5" style="color: var(--text-muted);">
                                <svg class="mb-3 text-muted" viewBox="0 0 24 24" width="40" height="40" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                    <circle cx="9" cy="7" r="4"></circle>
                                    <line x1="23" y1="11" x2="17" y2="11"></line>
                                </svg>
                                <div>No se encontraron clientes registrados con los filtros seleccionados.</div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer p-3 bg-light border-top-0 d-flex justify-content-between align-items-center">
            <p class="mb-0 text-muted" style="font-size: 0.875rem;" id="contadorClientes">
                Mostrando @(((List<Cliente>)ViewBag.Clientes)?.Count ?? 0) clientes
            </p>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .table { color: var(--text-primary); border-color: var(--border-color); }
        .table-hover tbody tr:hover { background: var(--sys-soft-bg); }
        .card { border-color: var(--border-color); background: var(--bg-sidebar); }
        .table-light { background-color: var(--bg-app); }
        .card-footer { background-color: var(--bg-app) !important; border-top: 1px solid var(--border-color) !important; }
    </style>
}

@section Scripts {
    <script src="~/js/clientes.js" asp-append-version="true"></script>
}
